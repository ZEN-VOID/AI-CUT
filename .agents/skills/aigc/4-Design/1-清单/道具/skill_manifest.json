{
  "schema": "skill-manifest/v1",
  "skill_id": "aigc.design.prop_list",
  "skill_path": ".agents/skills/aigc/4-Design/1-清单/道具",
  "entrypoint": {
    "script": ".agents/skills/aigc/4-Design/1-清单/道具/scripts/run_prop_list_pipeline.py",
    "runner": "python3",
    "args": [
      {
        "flag": "--input",
        "value": "{input_path}"
      },
      {
        "flag": "--output-dir",
        "value": "{output_dir}"
      }
    ]
  },
  "io": {
    "inputs": {
      "source": {
        "pattern": "3-Detail/第{episode}.json",
        "format": "json",
        "required": true
      }
    },
    "outputs": {
      "prop_catalog": {
        "pattern": "4-Design/道具/1-清单/第{episode}/道具清单.json",
        "format": "json",
        "required_fields": [
          "props[].design_context"
        ]
      },
      "manifest": {
        "pattern": "4-Design/道具/1-清单/第{episode}/_manifest.json",
        "format": "json"
      },
      "research_compat": {
        "pattern": "4-Design/道具/1-清单/第{episode}/道具研究.json",
        "format": "json"
      },
      "bridge_compat": {
        "pattern": "4-Design/道具/1-清单/第{episode}/prop_design_bridge.json",
        "format": "json",
        "required_fields": [
          "props"
        ]
      }
    },
    "fallback_inputs": [
      {
        "pattern": "编导/第{episode}.json",
        "format": "json"
      }
    ]
  },
  "scope": "episode",
  "tags": [
    "aigc",
    "design",
    "prop",
    "list"
  ]
}
