{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LibTV Subject Reference Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "flow",
    "project_root",
    "episode",
    "group_id",
    "group_source_path",
    "duration",
    "resolution",
    "ratio",
    "allow_libtv_prompt_optimization",
    "generation_mode",
    "modeType",
    "text2video_fallback_authorized",
    "canonical_reference_order",
    "reference_order_check",
    "reference_mapping_check",
    "left_input_edges",
    "image_placeholder_map",
    "subject_bindings",
    "libtv_images",
    "status"
  ],
  "properties": {
    "schema_version": { "const": "libtv-subject-reference-manifest/v1" },
    "flow": { "const": "subject_reference_flow" },
    "project_root": { "type": "string" },
    "episode": { "type": "string" },
    "group_id": { "type": "string", "pattern": "^[0-9]+-[0-9]+-[0-9]+$" },
    "group_source_path": { "type": "string" },
    "group_source_heading": { "type": "string" },
    "projectUuid": { "type": "string" },
    "projectUrl": { "type": "string" },
    "registry_path": { "type": "string" },
    "duration_estimate_seconds": { "type": "number" },
    "duration_source": { "type": "string" },
    "duration": { "type": "number", "minimum": 4, "maximum": 15 },
    "resolution": { "type": "string" },
    "ratio": { "type": "string" },
    "audio": { "type": "string" },
    "allow_libtv_prompt_optimization": { "type": "boolean" },
    "prompt_optimization_opt_in": { "type": "boolean" },
    "generation_mode": { "enum": ["omnireference_video", "text2video_fallback"] },
    "generation_mode_label": { "type": "string" },
    "modeType": { "enum": ["text2video", "singleImage2video", "frames2video", "image2video", "audio2video", "mixed2video"] },
    "modeType_source": { "type": "string" },
    "text2video_fallback_authorized": { "type": "boolean" },
    "handoff_prompt_separated_from_params_prompt": { "type": "boolean" },
    "params_prompt_contract": { "type": "array", "items": { "type": "string" } },
    "full_fenced_yaml_in_params_prompt": { "type": "boolean" },
    "subject_binding_table_in_params_prompt": { "type": "boolean" },
    "execution_metadata_in_params_prompt": { "type": "boolean" },
    "duplicate_subject_reference_allowed": { "type": "boolean" },
    "canonical_reference_order": {
      "type": "object",
      "properties": {
        "source": { "type": "string" },
        "order": { "type": "array", "items": { "type": "string" } },
        "preserve_yaml_list_order": { "type": "boolean" },
        "apply_to": { "type": "array", "items": { "type": "string" } },
        "forbidden_order_sources": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "reference_order_check": { "type": "string" },
    "reference_mapping_check": { "type": "string" },
    "dedupe_style_audio_constraints": { "type": "boolean" },
    "forbidden_prompt_phrases": { "type": "array", "items": { "type": "string" } },
    "subject_bindings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["yaml_name", "category", "binding_status"],
        "properties": {
          "yaml_name": { "type": "string" },
          "category": { "enum": ["角色", "场景", "道具"] },
          "canvas_node_name": { "type": "string" },
          "node_key": { "type": "string" },
          "url": { "type": "string" },
          "image_index": { "type": "integer", "minimum": 1 },
          "placeholder": { "type": "string", "pattern": "^\\{\\{Image [0-9]+\\}\\}$" },
          "usage": { "type": "string" },
          "binding_status": { "enum": ["active_reused", "uploaded", "manual_bound", "missing", "ambiguous", "excluded_due_to_budget"] },
          "registry_key": { "type": "string" },
          "local_source_path": { "type": "string" },
          "candidate_paths": { "type": "array", "items": { "type": "string" } },
          "disambiguation_evidence": { "type": "string" },
          "exclusion_reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "left_input_edges": {
      "type": "array",
      "maxItems": 9,
      "items": {
        "type": "object",
        "required": ["image_index", "placeholder", "yaml_name", "category", "node_key"],
        "properties": {
          "image_index": { "type": "integer", "minimum": 1 },
          "placeholder": { "type": "string", "pattern": "^\\{\\{Image [0-9]+\\}\\}$" },
          "yaml_name": { "type": "string" },
          "category": { "enum": ["角色", "场景", "道具"] },
          "node_key": { "type": "string" },
          "canvas_node_name": { "type": "string" },
          "url": { "type": "string" },
          "connect_status": { "enum": ["planned", "connected", "verified", "failed"] }
        },
        "additionalProperties": true
      }
    },
    "image_placeholder_map": {
      "type": "array",
      "maxItems": 9,
      "items": {
        "type": "object",
        "required": ["image_index", "placeholder", "yaml_name", "node_key"],
        "properties": {
          "image_index": { "type": "integer", "minimum": 1 },
          "placeholder": { "type": "string", "pattern": "^\\{\\{Image [0-9]+\\}\\}$" },
          "yaml_name": { "type": "string" },
          "node_key": { "type": "string" },
          "verified_by": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "libtv_images": {
      "type": "array",
      "maxItems": 9,
      "items": {
        "type": "object",
        "required": ["image_index", "placeholder", "yaml_name", "node_key", "url", "usage"],
        "properties": {
          "image_index": { "type": "integer", "minimum": 1 },
          "placeholder": { "type": "string", "pattern": "^\\{\\{Image [0-9]+\\}\\}$" },
          "yaml_name": { "type": "string" },
          "category": { "enum": ["角色", "场景", "道具"] },
          "node_key": { "type": "string" },
          "url": { "type": "string" },
          "usage": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "excluded_from_libtv_images": { "type": "array" },
    "excluded_due_to_budget": { "type": "array" },
    "execution_id": { "type": "string" },
    "groupNodeKey": { "type": "string" },
    "video_node_key": { "type": "string" },
    "executor_skill": { "const": ".agents/skills/cli/libTV" },
    "status": { "enum": ["planned", "submitted", "completed", "blocked", "needs_rework", "placeholder"] }
  },
  "additionalProperties": true
}
