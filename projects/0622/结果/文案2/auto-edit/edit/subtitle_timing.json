    {
      "index": 1,
      "start": 0.081,
      "end": 1.241,
      "text": "AI 漫剧行业格局",
      "script_span": {
        "start_char": 0,
        "end_char": 9
      }
    },
    {
      "index": 2,
      "start": 1.251,
      "end": 2.311,
      "text": "迎来颠覆性变革",
      "script_span": {
        "start_char": 9,
        "end_char": 16
      }
    },
    {
      "index": 3,
      "start": 2.321,
      "end": 3.674,
      "text": "随着 Gemini Three",
      "script_span": {
        "start_char": 17,
        "end_char": 32
      }
    },
    {
      "index": 4,
      "start": 3.684,
      "end": 5.453,
      "text": "与 GPT Images Two",
      "script_span": {
        "start_char": 33,
        "end_char": 49
      }
    },
    {
      "index": 5,
      "start": 5.463,
      "end": 6.37,
      "text": "两款模型落地",
      "script_span": {
        "start_char": 50,
        "end_char": 56
      }
    },
    {
      "index": 6,
      "start": 6.38,
      "end": 8.158,
      "text": "赛道竞争已然尘埃落定",
      "script_span": {
        "start_char": 57,
        "end_char": 67
      }
    },
    {
      "index": 7,
      "start": 8.168,
      "end": 9.446,
      "text": "工具操作极简",
      "script_span": {
        "start_char": 68,
        "end_char": 74
      }
    },
    {
      "index": 8,
      "start": 9.456,
      "end": 10.749,
      "text": "导入小说文本后",
      "script_span": {
        "start_char": 75,
        "end_char": 82
      }
    },
    {
      "index": 9,
      "start": 10.759,
      "end": 12.787,
      "text": "大模型自动完成剧情推演",
      "script_span": {
        "start_char": 83,
        "end_char": 94
      }
    },
    {
      "index": 10,
      "start": 12.797,
      "end": 14.549,
      "text": "快速输出完整拍摄脚本",
      "script_span": {
        "start_char": 95,
        "end_char": 105
      }
    },
    {
      "index": 11,
      "start": 14.559,
      "end": 16.222,
      "text": "省去钻研复杂提示词",
      "script_span": {
        "start_char": 106,
        "end_char": 115
      }
    },
    {
      "index": 12,
      "start": 16.232,
      "end": 17.444,
      "text": "手动编写分镜指令",
      "script_span": {
        "start_char": 116,
        "end_char": 124
      }
    },
    {
      "index": 13,
      "start": 17.454,
      "end": 18.208,
      "text": "的繁琐步骤",
      "script_span": {
        "start_char": 124,
        "end_char": 129
      }
    },
    {
      "index": 14,
      "start": 18.218,
      "end": 20.112,
      "text": "自动生成叙事流畅",
      "script_span": {
        "start_char": 130,
        "end_char": 138
      }
    },
    {
      "index": 15,
      "start": 20.122,
      "end": 21.907,
      "text": "院线级质感的分镜内容",
      "script_span": {
        "start_char": 139,
        "end_char": 149
      }
    },
    {
      "index": 16,
      "start": 21.917,
      "end": 23.36,
      "text": "长期困扰创作者的",
      "script_span": {
        "start_char": 151,
        "end_char": 159
      }
    },
    {
      "index": 17,
      "start": 23.37,
      "end": 25.162,
      "text": "人物形象不统一问题",
      "script_span": {
        "start_char": 159,
        "end_char": 168
      }
    },
    {
      "index": 18,
      "start": 25.172,
      "end": 26.079,
      "text": "得到彻底根治",
      "script_span": {
        "start_char": 168,
        "end_char": 174
      }
    },
    {
      "index": 19,
      "start": 26.089,
      "end": 27.987,
      "text": "一键生成标准人物三视图",
      "script_span": {
        "start_char": 175,
        "end_char": 186
      }
    },
    {
      "index": 20,
      "start": 27.997,
      "end": 30.082,
      "text": "专属场景与配套道具",
      "script_span": {
        "start_char": 187,
        "end_char": 196
      }
    },
    {
      "index": 21,
      "start": 30.092,
      "end": 32.238,
      "text": "保障角色全片形象统一",
      "script_span": {
        "start_char": 197,
        "end_char": 207
      }
    },
    {
      "index": 22,
      "start": 32.248,
      "end": 34.058,
      "text": "支持古风、赛璐璐",
      "script_span": {
        "start_char": 208,
        "end_char": 216
      }
    },
    {
      "index": 23,
      "start": 34.068,
      "end": 35.449,
      "text": "国风三维、日系二次元",
      "script_span": {
        "start_char": 217,
        "end_char": 227
      }
    },
    {
      "index": 24,
      "start": 35.459,
      "end": 37.187,
      "text": "等多元画风一键切换",
      "script_span": {
        "start_char": 227,
        "end_char": 236
      }
    },
    {
      "index": 25,
      "start": 37.197,
      "end": 38.804,
      "text": "全程云端算力支撑",
      "script_span": {
        "start_char": 237,
        "end_char": 245
      }
    },
    {
      "index": 26,
      "start": 38.814,
      "end": 40.332,
      "text": "对本地设备配置无要求",
      "script_span": {
        "start_char": 246,
