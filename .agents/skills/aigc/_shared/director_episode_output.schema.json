{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aigc/_shared/director_episode_output.schema.json",
  "title": "AIGC Director Episode Output Schema",
  "description": "用于 `1-Planning/3-分组 -> 2-Global -> 3-Detail` 的共享 JSON 输出真源。当前 canonical 输出按 `metadata / final_output` 双槽组织；`thinking_chain` 仅为兼容旧 root 的可选摘要槽，默认不输出。",
  "type": "object",
  "allOf": [
    {
      "if": {
        "properties": {
          "metadata": {
            "properties": {
              "document_phase": {
                "enum": [
                  "detail_in_progress",
                  "ready"
                ]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "final_output": {
            "properties": {
              "main_content": {
                "properties": {
                  "分镜组列表": {
                    "items": {
                      "properties": {
                        "分镜明细": {
                          "minItems": 1
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "metadata": {
            "properties": {
              "document_phase": {
                "const": "directing_in_progress"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "final_output": {
            "properties": {
              "main_content": {
                "properties": {
                  "分镜组列表": {
                    "items": {
                      "properties": {
                        "组间设计": {
                          "properties": {
                            "全局风格": {
                              "maxLength": 220
                            },
                            "类型元素": {
                              "maxLength": 50
                            },
                            "导演意图": {
                              "maxLength": 100
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false,
  "required": [
    "metadata",
    "final_output"
  ],
  "properties": {
    "metadata": {
      "title": "元数据",
      "description": "声明本次导演集级结构化产物的识别、路由和追踪字段。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "skill_id",
        "template_version",
        "source_route",
        "episode_id",
        "document_phase",
        "created_at"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "aigc/director-episode-output/v1"
        },
        "skill_id": {
          "type": "string",
          "description": "生成本结构化产物的主技能标识。"
        },
        "template_version": {
          "type": "string",
          "description": "当前模板版本。"
        },
        "source_route": {
          "type": "string",
          "description": "上游来源或执行路由，例如 `2-Global/导演意图 -> 3-Detail`。"
        },
        "source_profile": {
          "type": "object",
          "description": "上游故事源类型及预设保护模式，供 `3-Detail` 读取。",
          "additionalProperties": false,
          "required": [
            "source_type",
            "preset_retention_mode",
            "detail_expansion_mode",
            "locked_preset_axes",
            "preset_registry"
          ],
          "properties": {
            "source_type": {
              "type": "string",
              "enum": [
                "novel_original",
                "script_original",
                "storyboard_script",
                "oral_story_transcript",
                "hybrid_story_text"
              ]
            },
            "preset_retention_mode": {
              "type": "string",
              "enum": [
                "standard",
                "preserve_and_extend",
                "preserve_only"
              ]
            },
            "detail_expansion_mode": {
              "type": "string",
              "enum": [
                "free_expansion",
                "guided_expansion",
                "respect_storyboard_presets"
              ]
            },
            "locked_preset_axes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "preset_registry": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/preset_anchor"
              }
            }
          }
        },
        "episode_id": {
          "type": "string",
          "description": "集标识，例如 `第1集`。"
        },
        "document_phase": {
          "type": "string",
          "enum": [
            "bootstrapped",
            "planning_seeded",
            "directing_in_progress",
            "detail_in_progress",
            "ready"
          ],
          "description": "当前文档所处的生命周期阶段。"
        },
        "created_at": {
          "type": "string",
          "description": "ISO 8601 时间戳。"
        }
      }
    },
    "thinking_chain": {
      "title": "思维链",
      "description": "兼容旧 root 的可选摘要槽；默认不输出，也不作为阶段写回或验收必填项。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "thinking_goal",
        "key_steps",
        "conclusion"
      ],
      "properties": {
        "thinking_goal": {
          "type": "string"
        },
        "key_steps": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "#/$defs/thinking_step"
          }
        },
        "conclusion": {
          "type": "string"
        }
      }
    },
    "final_output": {
      "title": "主内容",
      "description": "真正交给下游阶段消费的导演集级结构化内容。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deliverable_type",
        "main_content",
        "acceptance_notes"
      ],
      "properties": {
        "deliverable_type": {
          "type": "string",
          "const": "director_episode_output"
        },
        "main_content": {
          "title": "主内容",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "分镜组列表"
          ],
          "properties": {
            "分镜组列表": {
              "type": "array",
              "minItems": 0,
              "items": {
                "$ref": "#/$defs/storyboard_group"
              }
            }
          }
        },
        "acceptance_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "thinking_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "focus",
        "evidence",
        "judgment"
      ],
      "properties": {
        "step_id": {
          "type": "string"
        },
        "focus": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        },
        "judgment": {
          "type": "string"
        }
      }
    },
    "preset_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "anchor_id",
        "source_span",
        "lock_level",
        "owned_axes",
        "expandable_axes",
        "forbidden_changes",
        "projected_group_ids",
        "projected_shot_mode"
      ],
      "properties": {
        "anchor_id": {
          "type": "string"
        },
        "source_span": {
          "type": "string"
        },
        "lock_level": {
          "type": "string",
          "enum": [
            "hard_lock",
            "soft_lock",
            "reference_only"
          ]
        },
        "owned_axes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expandable_axes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_changes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "projected_group_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "projected_shot_mode": {
          "type": "string",
          "enum": [
            "single_anchor_single_shot",
            "single_anchor_multi_shot",
            "multi_anchor_fixed",
            "reference_only"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "storyboard_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "分镜组ID",
        "总时长",
        "剧本正文",
        "组间设计",
        "分镜明细"
      ],
      "properties": {
        "分镜组ID": {
          "type": "string"
        },
        "总时长": {
          "type": "number",
          "minimum": 0,
          "description": "单位：秒。"
        },
        "剧本正文": {
          "type": "string",
          "description": "该分镜组在 `1-Planning/3-分组/第N集.md` 中的完整正文整理结果；除重复组号标题外不得摘要化。"
        },
        "组间设计": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "全局风格",
            "类型元素",
            "导演意图",
            "出场角色及穿搭"
          ],
          "properties": {
            "全局风格": {
              "type": "string",
              "description": "由 2-Global 直接引用 `全局风格.md` 中字段标题 `全局风格` 的项目级无污染统一风格前缀，默认不超过 220 字。"
            },
            "类型元素": {
              "type": "string",
              "description": "由 2-Global 直接引用 `类型元素.md` 中命中组字段标题 `类型元素` 的组级类型信号，默认不超过 50 字。"
            },
            "导演意图": {
              "type": "string",
              "description": "由 2-Global 直接引用 `导演意图.md` 中命中组字段标题 `导演意图` 的组级执行导向，默认不超过 100 字。"
            },
            "出场角色及穿搭": {
              "type": "string",
              "description": "组级角色服装摘要槽；格式建议为 `角色名-服装简述`，多个角色用 `；` 分隔。`2-Global` 可先留空字符串占位，`3-Detail` 在镜级明细稳定后应回填。"
            }
          }
        },
        "分镜明细": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "#/$defs/shot_detail"
          }
        }
      }
    },
    "shot_detail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "分镜ID",
        "时间段",
        "角色背景面",
        "角色站位走位",
        "道具及状态",
        "分镜表现",
        "角色表现",
        "运镜手法",
        "场景氛围",
        "摄影美学"
      ],
      "properties": {
        "分镜ID": {
          "type": "string"
        },
        "时间段": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "开始秒",
            "结束秒"
          ],
          "properties": {
            "开始秒": {
              "type": "number",
              "minimum": 0
            },
            "结束秒": {
              "type": "number",
              "minimum": 0
            }
          },
          "description": "以秒为单位的闭区间。"
        },
        "角色背景面": {
          "type": "string",
          "description": "在角色中心主义下，交代当前镜头作为角色背景的具体场景方位面，例如东西南北面、入口/出口、内外侧或墙面/尽头关系。"
        },
        "角色站位走位": {
          "type": "string",
          "description": "明确角色在镜头中的当前位置、相对层次与位移路径，要求包含走位/移位信息，不只写静态站位。服装信息默认上收至 `组间设计.出场角色及穿搭`。"
        },
        "道具及状态": {
          "type": "string"
        },
        "分镜表现": {
          "type": "string"
        },
        "景别": {
          "type": "string",
          "description": "可选镜头描述子槽；例如 `中景`、`近景`、`特写`。示例值仅用于说明字段形状，不代表默认推荐值。"
        },
        "镜头属性": {
          "type": "string",
          "description": "可选镜头描述子槽；例如 `定场镜头`、`关系建立镜头`、`反应镜头`。示例值仅用于说明字段形状，不代表默认推荐值。"
        },
        "镜头框架": {
          "type": "string",
          "description": "可选镜头描述子槽；压缩主体/陪体/背景关系与构图结果。示例值仅用于说明字段形状，不代表默认推荐值。"
        },
        "镜头类型": {
          "type": "string",
          "description": "可选镜头描述子槽；说明当前镜头在叙事链中的职责。示例值仅用于说明字段形状，不代表默认推荐值。"
        },
        "镜头视角": {
          "type": "string",
          "description": "可选镜头描述子槽；例如 `平视`、`俯视`、`仰视`、`过肩视角`。示例值仅用于说明字段形状，不代表默认推荐值。"
        },
        "角色表现": {
          "type": "string"
        },
        "运镜手法": {
          "type": "string"
        },
        "场景氛围": {
          "type": "string"
        },
        "摄影美学": {
          "type": "string"
        },
        "转场特效": {
          "type": "string",
          "description": "非必须；仅在该镜头需要显式转场或特效桥接时填写。"
        }
      }
    }
  },
  "examples": [
    {
      "metadata": {
        "schema_version": "aigc/director-episode-output/v1",
        "skill_id": "aigc-global",
        "template_version": "global-seed-v1",
        "source_route": "2-Global group_design seed",
        "episode_id": "第1集",
        "document_phase": "directing_in_progress",
        "created_at": "2026-04-12T10:00:00-07:00"
      },
      "final_output": {
        "deliverable_type": "director_episode_output",
        "main_content": {
          "分镜组列表": [
            {
              "分镜组ID": "1-1-1",
              "总时长": 18,
              "剧本正文": "角色A推门进入空旷长廊，角色B在尽头停住脚步。",
              "组间设计": {
                "全局风格": "低照度心理悬疑影视风格，低调照明、空气介质交互与胶片化质感统一，整体维持遮蔽、压抑、延迟揭示的不安基调。",
                "类型元素": "悬疑压迫优先，克制抒情。",
                "导演意图": "先让空间压住观众，再用人物迟疑把呼吸拖慢，焦点始终围绕“谁先打破僵局”。",
                "出场角色及穿搭": ""
              },
              "分镜明细": []
            }
          ]
        },
        "acceptance_notes": [
          "2-Global 阶段允许先写完整分镜组壳与组间设计，分镜明细可暂为空数组。",
          "3-Detail 必须优先继承这三条组级上下文，再补镜级字段。"
        ]
      }
    },
    {
      "metadata": {
        "schema_version": "aigc/director-episode-output/v1",
        "skill_id": "aigc-detail",
        "template_version": "v1",
        "source_route": "2-Global/导演意图 -> 3-Detail",
        "episode_id": "第1集",
        "document_phase": "detail_in_progress",
        "created_at": "2026-04-10T12:00:00-07:00"
      },
      "final_output": {
        "deliverable_type": "director_episode_output",
        "main_content": {
          "分镜组列表": [
            {
              "分镜组ID": "1-1-1",
              "总时长": 18,
              "剧本正文": "角色A推门进入空旷长廊，角色B在尽头停住脚步。",
              "组间设计": {
                "全局风格": "低照度心理悬疑影视风格，低调照明与压抑质感统一，整体维持遮蔽、延迟揭示与不安感。",
                "类型元素": "悬疑压迫感优先，避免抒情化稀释。",
                "导演意图": "观众应先被空间压扁，再被人物迟疑拉慢呼吸。",
                "出场角色及穿搭": "角色A-深灰风衣与黑色长靴；角色B-浅色衬衫外搭旧西装"
              },
              "分镜明细": [
                {
                  "分镜ID": "1-1-1-1",
                  "时间段": {
                    "开始秒": 0,
                    "结束秒": 6
                  },
                  "角色背景面": "长廊西端入口朝东的一侧墙面与尽头出口方向同时作为角色对峙背景。",
                  "角色站位走位": "角色A从前景左侧推门入画并向中轴压近半步；角色B留在远端居中，先停住后微微后撤。",
                  "道具及状态": "门把仍在轻微晃动，墙边旧灯管间歇闪烁。",
                  "分镜表现": "用前后景纵深压出进入感与未知距离。",
                  "景别": "中景",
                  "镜头属性": "定场镜头",
                  "镜头框架": "双主体对峙，前后景分层。",
                  "镜头类型": "叙事镜头",
                  "镜头视角": "平视",
                  "角色表现": "角色A先试探后压近，角色B保持迟滞不动。",
                  "运镜手法": "轻微前压后停顿，最后以极慢速收束。",
                  "场景氛围": "空气偏冷，走廊回声略长，静压先行。",
                  "摄影美学": "冷色主导，边缘高光克制，阴影层次保留。",
                  "转场特效": ""
                }
              ]
            }
          ]
        },
        "acceptance_notes": [
          "所有组级字段必须能直接被 3-Detail 继承。",
          "转场特效为空时不应强行补写。",
          "本 example 中的镜头描述子槽只用于展示 schema 形状，不代表默认值，后续任务必须按当前镜头重填。"
        ]
      }
    },
    {
      "metadata": {
        "schema_version": "aigc/director-episode-output/v1",
        "skill_id": "aigc-detail",
        "template_version": "bootstrap-v1",
        "source_route": "2-Global -> 3-Detail bootstrap",
        "episode_id": "第2集",
        "document_phase": "bootstrapped",
        "created_at": "2026-04-10T12:30:00-07:00"
      },
      "final_output": {
        "deliverable_type": "director_episode_output",
        "main_content": {
          "分镜组列表": []
        },
        "acceptance_notes": [
          "允许 3-Detail 在首次进入时自动创建 bootstrapped 空壳。",
          "后续由 3-Detail 继续补全。"
        ]
      }
    }
  ]
}
