{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "nine_blade_comic_prompts.v1",
  "type": "object",
  "required": [
    "schema_version",
    "generation_contract",
    "main_character_lock",
    "scene_continuity_bible",
    "style_bible",
    "character_locks",
    "comic_text_system",
    "pages",
    "global_negative_prompt"
  ],
  "$defs": {
    "page_group_meta": {
      "type": "object",
      "required": [
        "group_id",
        "group_index",
        "total_groups",
        "estimated_source_chars",
        "target_source_chars",
        "source_span_summary",
        "rhythm_rationale"
      ],
      "properties": {
        "group_id": {"type": "string", "minLength": 4},
        "group_index": {"type": "integer", "minimum": 1},
        "total_groups": {"type": "integer", "minimum": 1},
        "estimated_source_chars": {"type": "integer", "minimum": 1},
        "target_source_chars": {"type": "integer", "minimum": 1},
        "source_span_summary": {"type": "string", "minLength": 4},
        "rhythm_rationale": {"type": "string", "minLength": 12}
      }
    },
    "continuity_context": {
      "type": "object",
      "required": ["inherit_global_locks", "same_visual_dna_rule"],
      "properties": {
        "inherit_global_locks": {"type": "boolean"},
        "same_visual_dna_rule": {"type": "string", "minLength": 20},
        "previous_group_hook": {"type": "string"},
        "next_group_hook": {"type": "string"}
      }
    },
    "text_system_entry": {
      "type": "object",
      "required": ["visual_form", "placement_rule", "legibility_rule", "max_chars"],
      "properties": {
        "visual_form": {"type": "string", "minLength": 8},
        "placement_rule": {"type": "string", "minLength": 12},
        "legibility_rule": {"type": "string", "minLength": 12},
        "max_chars": {"type": "integer", "minimum": 1}
      }
    },
    "text_slot": {
      "type": "object",
      "required": ["type", "text", "placement", "bubble_style", "inside_panel"],
      "properties": {
        "type": {
          "enum": ["dialogue", "narration", "inner_monologue", "sfx"]
        },
        "speaker_id": {"type": "string", "minLength": 1},
        "text": {"type": "string", "minLength": 1},
        "placement": {
          "enum": [
            "near_speaker_inside_panel",
            "panel_edge_caption",
            "gutter_edge_caption",
            "near_thinker_inside_panel",
            "inner_caption_inside_panel",
            "integrated_with_action_inside_panel"
          ]
        },
        "bubble_style": {
          "enum": [
            "speech_bubble",
            "caption_box",
            "thought_bubble",
            "inner_caption",
            "integrated_sfx"
          ]
        },
        "inside_panel": {"type": "boolean"}
      },
      "allOf": [
        {
          "if": {"properties": {"type": {"const": "dialogue"}}, "required": ["type"]},
          "then": {
            "required": ["speaker_id"],
            "properties": {
              "text": {"type": "string", "minLength": 1, "maxLength": 18},
              "placement": {"const": "near_speaker_inside_panel"},
              "bubble_style": {"const": "speech_bubble"},
              "inside_panel": {"const": true}
            }
          }
        },
        {
          "if": {"properties": {"type": {"const": "narration"}}, "required": ["type"]},
          "then": {
            "properties": {
              "text": {"type": "string", "minLength": 1, "maxLength": 24},
              "placement": {"enum": ["panel_edge_caption", "gutter_edge_caption"]},
              "bubble_style": {"const": "caption_box"}
            }
          }
        },
        {
          "if": {"properties": {"type": {"const": "inner_monologue"}}, "required": ["type"]},
          "then": {
            "required": ["speaker_id"],
            "properties": {
              "text": {"type": "string", "minLength": 1, "maxLength": 20},
              "placement": {"enum": ["near_thinker_inside_panel", "inner_caption_inside_panel"]},
              "bubble_style": {"enum": ["thought_bubble", "inner_caption"]},
              "inside_panel": {"const": true}
            }
          }
        },
        {
          "if": {"properties": {"type": {"const": "sfx"}}, "required": ["type"]},
          "then": {
            "properties": {
              "text": {"type": "string", "minLength": 1, "maxLength": 6},
              "placement": {"const": "integrated_with_action_inside_panel"},
              "bubble_style": {"const": "integrated_sfx"},
              "inside_panel": {"const": true}
            }
          }
        }
      ]
    }
  },
  "properties": {
    "schema_version": {
      "const": "nine_blade_comic_prompts.v1"
    },
    "page_group": {
      "$ref": "#/$defs/page_group_meta",
      "description": "Optional but recommended group identity metadata when the episode is partitioned into multiple page-groups."
    },
    "continuity_context": {
      "$ref": "#/$defs/continuity_context",
      "description": "Optional but recommended cross-group continuity inheritance metadata."
    },
    "generation_contract": {
      "type": "object",
      "required": ["provider", "call_mode", "image_count", "page_aspect_ratio", "hard_constraints"],
      "properties": {
        "provider": {"const": "seedream"},
        "call_mode": {"const": "single_request_sequential"},
        "image_count": {"const": 9},
        "page_aspect_ratio": {"const": "9:16"},
        "seedream": {
          "type": "object",
          "properties": {
            "model": {"type": "string"},
            "max_images": {"const": 9},
            "size": {"type": "string"},
            "stream": {"type": "boolean"}
          }
        },
        "hard_constraints": {
          "type": "array",
          "description": "Must include 9 separate pages, no collage, no same-scene variants, and character/scene consistency across all pages.",
          "minItems": 3,
          "items": {"type": "string"}
        }
      }
    },
    "main_character_lock": {
      "type": "object",
      "required": ["character_id", "name", "anchor_prompt"],
      "properties": {
        "character_id": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1},
        "anchor_prompt": {
          "type": "string",
          "minLength": 40,
          "description": "Primary character anchor injected into every page prompt, e.g. Character locked across all panels: [name], [stable appearance/costume/silhouette]."
        }
      }
    },
    "scene_continuity_bible": {
      "type": "object",
      "required": ["default_rule", "scene_locks"],
      "properties": {
        "default_rule": {"type": "string", "minLength": 20},
        "scene_locks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["scene_id", "name", "anchor_prompt"],
            "properties": {
              "scene_id": {"type": "string", "minLength": 1},
              "name": {"type": "string", "minLength": 1},
              "anchor_prompt": {
                "type": "string",
                "minLength": 40,
                "description": "Named scene anchor used to keep architecture, landmark props, lighting, and spatial geography consistent across relevant pages."
              }
            }
          }
        }
      }
    },
    "style_bible": {"type": "object"},
    "character_locks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["character_id", "name", "anchor_prompt"],
        "properties": {
          "character_id": {"type": "string", "minLength": 1},
          "name": {"type": "string", "minLength": 1},
          "anchor_prompt": {
            "type": "string",
            "minLength": 20,
            "description": "Recurring character anchor used when the page contains multiple named characters."
          }
        }
      }
    },
    "comic_text_system": {
      "type": "object",
      "required": ["dialogue", "narration", "inner_monologue", "sfx"],
      "properties": {
        "dialogue": {
          "allOf": [
            {"$ref": "#/$defs/text_system_entry"},
            {"properties": {"max_chars": {"const": 18}}}
          ]
        },
        "narration": {
          "allOf": [
            {"$ref": "#/$defs/text_system_entry"},
            {"properties": {"max_chars": {"const": 24}}}
          ]
        },
        "inner_monologue": {
          "allOf": [
            {"$ref": "#/$defs/text_system_entry"},
            {"properties": {"max_chars": {"const": 20}}}
          ]
        },
        "sfx": {
          "allOf": [
            {"$ref": "#/$defs/text_system_entry"},
            {"properties": {"max_chars": {"const": 6}}}
          ]
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {
        "type": "object",
        "required": [
          "page_number",
          "page_role",
          "source_fragment",
          "active_character_ids",
          "scene_id",
          "layout",
          "panels",
          "page_number_overlay",
          "positive_prompt"
        ],
        "properties": {
          "page_number": {"type": "integer", "minimum": 1, "maximum": 9},
          "page_role": {"type": "string"},
          "source_fragment": {"type": "string"},
          "active_character_ids": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "scene_id": {"type": "string", "minLength": 1},
          "layout": {
            "type": "object",
            "required": ["aspect_ratio", "layout_id", "panel_count", "panel_ratios"],
            "properties": {
              "aspect_ratio": {"const": "9:16"},
              "layout_id": {"type": "string"},
              "panel_count": {"type": "integer", "minimum": 2, "maximum": 5},
              "panel_ratios": {
                "type": "array",
                "items": {"type": "string"}
              }
            }
          },
          "panels": {
            "type": "array",
            "minItems": 2,
            "maxItems": 5,
            "items": {
              "type": "object",
              "required": ["panel_id", "shot", "action", "text_slots"],
              "properties": {
                "panel_id": {"type": "string"},
                "shot": {"type": "string"},
                "action": {"type": "string"},
                "comic_techniques": {
                  "type": "array",
                  "items": {"type": "string"}
                },
                "text_slots": {
                  "type": "array",
                  "items": {"$ref": "#/$defs/text_slot"}
                }
              }
            }
          },
          "page_number_overlay": {
            "type": "object",
            "required": ["text", "position", "style_prompt"],
            "properties": {
              "text": {"type": "string", "pattern": "^[1-9]$"},
              "position": {"const": "bottom-right"},
              "style_prompt": {
                "type": "string",
                "minLength": 20,
                "description": "Must require a readable bottom-right numeric page number using digits only."
              }
            }
          },
          "positive_prompt": {
            "type": "string",
            "description": "Page prompt must mention vertical 9:16 comic page, inject the main character anchor, include active multi-character continuity, inject the scene anchor, include a bottom-right digits-only page number rule, and explicitly describe readable Chinese comic lettering for the text slot types used on that page."
          }
        }
      }
    },
    "global_negative_prompt": {"type": "string"}
  }
}
