# ==============================================
# AIGC数字映画株式会社 - 环境变量配置模板
# ==============================================
# 说明: 复制此文件为 .env 并填入真实的API密钥
# 注意: .env 文件已在 .gitignore 中,不会被提交到Git


# ==============================================
# 可灵 (Kling) API 配置
# ==============================================
# 获取方式: https://klingai.kuaishou.com/
KLING_ACCESS_KEY=your_kling_access_key_here
KLING_SECRET_KEY=your_kling_secret_key_here


# ==============================================
# OpenRouter API 配置
# ==============================================
# 用于: VEO 3.1, Sora 2 Pro, Nano-banana, Ideogram等
# 获取方式: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here


# ==============================================
# Antigravity Messages API 配置 (Nano Banana Pro)
# ==============================================
# 用于: gemini-3-pro-image* 文生图/图生图
ANTIGRAVITY_API_KEY=your_antigravity_api_key_here
ANTIGRAVITY_BASE_URL=http://127.0.0.1:7861
ANTIGRAVITY_MODEL=gemini-3-pro-image-16x9
ANTIGRAVITY_OUTPUT_DIR=.
ANTIGRAVITY_IMAGE_PATH=input/example.png


# ==============================================
# Google Gemini API 配置
# ==============================================
# 用于: ZTL餐饮数智化平面设计工作台 (图像生成, 多模态)
# 获取方式: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here
ANYFAST_PLATFORM_URL=https://www.anyfas.ai
ANYFAST_API_BASE_URL=https://fw2afus.ent.acc.kurtisasia.com
ANYFAST_DOCS_URL=https://docs.anyfast.ai
ANYFAST_API_KEY=your_anyfast_api_key_here
ANYFAST_DOUBAO_SEED_2_0_PRO_API_KEY=your_doubao_seed_2_0_pro_api_key_here
DXJ2_DEFAULT_MODEL=gemini-3.1-flash-image-preview


# ==============================================
# Minimax API 配置
# ==============================================
# 用于: 语音合成(TTS)、音乐生成、视频生成
# 获取方式: https://platform.minimaxi.com/
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_GROUP_ID=your_minimax_group_id_here


# ==============================================
# 腾讯云 COS (对象存储) 配置
# ==============================================
# 用于: 本地文件上传到云端,生成公开URL
# 获取方式: https://console.cloud.tencent.com/cam/capi
COS_SECRET_ID=your_tencent_cos_secret_id_here
COS_SECRET_KEY=your_tencent_cos_secret_key_here
COS_BUCKET=your_bucket_name_here
COS_REGION=ap-guangzhou


# ==============================================
# GitHub API 配置
# ==============================================
# 用于: GitHub MCP服务器,仓库管理、Issue处理等
# 获取方式: https://github.com/settings/tokens
# 权限要求: repo, workflow, write:packages
GITHUB_TOKEN=your_github_personal_access_token_here


# ==============================================
# 飞书 (Lark) API 配置
# ==============================================
# 用于: 飞书MCP服务器,多维表格、文档、群聊操作
# 获取方式: https://open.feishu.cn/app
LARK_APP_ID=your_lark_app_id_here
LARK_APP_SECRET=your_lark_app_secret_here


# ==============================================
# 通义万相 (DashScope) API 配置
# ==============================================
# 用于: 阿里云通义万相图像生成(备用)
# 获取方式: https://dashscope.console.aliyun.com/apiKey
DASHSCOPE_API_KEY=your_dashscope_api_key_here


# ==============================================
# Anthropic API 配置 (可选)
# ==============================================
# 用于: Claude API直接调用（如需直接调用 Claude）
# 获取方式: https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here


# ==============================================
# 配置验证
# ==============================================
# 完成配置后,可运行以下命令验证:
# python scripts/check_env.py
