{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LibTV Canvas Active Registry",
  "type": "object",
  "required": ["schema_version", "projectUuid", "entries"],
  "properties": {
    "schema_version": { "const": "libtv-canvas-active-registry/v1" },
    "project_root": { "type": "string" },
    "projectUuid": { "type": "string", "minLength": 1 },
    "projectUrl": { "type": "string" },
    "updated_at": { "type": "string" },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "registry_key",
          "yaml_name",
          "category",
          "canvas_node_name",
          "node_key",
          "url",
          "active",
          "status"
        ],
        "properties": {
          "registry_key": { "type": "string" },
          "yaml_name": { "type": "string", "minLength": 1 },
          "category": { "enum": ["角色", "场景", "道具"] },
          "canvas_node_name": { "type": "string", "minLength": 1 },
          "node_key": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "minLength": 1 },
          "active": { "type": "boolean" },
          "status": { "enum": ["active", "inactive", "ambiguous", "replaced", "missing"] },
          "source_type": { "enum": ["canvas_existing", "uploaded_multiview", "uploaded_main", "manual_binding"] },
          "source_path": { "type": "string" },
          "source_fingerprint": { "type": "string" },
          "last_verified_at": { "type": "string" },
          "notes": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
