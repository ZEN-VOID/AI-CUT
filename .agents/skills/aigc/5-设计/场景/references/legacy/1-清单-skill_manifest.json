{
  "schema": "skill-manifest/v1",
  "skill_id": "aigc.design.scene_list",
  "skill_path": ".agents/skills/aigc/5-设计/1-清单/场景",
  "entrypoint": {
    "script": ".agents/skills/aigc/5-设计/1-清单/场景/scripts/run_scene_list_pipeline.py",
    "runner": "python3",
    "args": [
      {
        "flag": "--input",
        "value": "{input_path}"
      },
      {
        "flag": "--output-dir",
        "value": "{output_dir}"
      }
    ]
  },
  "io": {
    "inputs": {
      "source": {
        "pattern": "3-Detail/第{episode}.json",
        "format": "json",
        "required": true
      }
    },
    "outputs": {
      "scene_catalog": {
        "pattern": "5-设计/场景/1-清单/第{episode}/场景清单.json",
        "format": "json",
        "required_fields": [
          "scenes",
          "group_scene_map"
        ]
      },
      "scene_research": {
        "pattern": "5-设计/场景/1-清单/第{episode}/场景研究.json",
        "format": "json",
        "required_fields": [
          "scenes[].evidence_ledger",
          "scenes[].scene_bible_card"
        ]
      },
      "scene_bridge": {
        "pattern": "5-设计/场景/1-清单/第{episode}/scene_design_bridge.json",
        "format": "json",
        "required_fields": [
          "scenes[].design_bridge_profile"
        ]
      },
      "manifest": {
        "pattern": "5-设计/场景/1-清单/第{episode}/_manifest.json",
        "format": "json"
      }
    },
    "fallback_inputs": [
      {
        "pattern": "编导/第{episode}.json",
        "format": "json"
      }
    ]
  },
  "scope": "episode",
  "tags": [
    "aigc",
    "design",
    "scene",
    "list"
  ]
}
