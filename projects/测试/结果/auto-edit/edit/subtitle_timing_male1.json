  "cues": [
    {
      "index": 1,
      "start": 0.079,
      "end": 2.606,
      "duration": 2.526,
      "text": "我靠，ai漫剧赛道直接他妈大结局了。",
      "speech_interval": {
        "start": 0.124,
        "end": 2.536
      }
    },
    {
      "index": 2,
      "start": 2.927,
      "end": 5.71,
      "duration": 2.783,
      "text": "Gemini three加 gptT\nimages two 的出现，",
      "speech_interval": {
        "start": 2.972,
        "end": 5.64
      }
    },
    {
      "index": 3,
      "start": 6.092,
      "end": 7.325,
      "duration": 1.233,
      "text": "直接宣布了比赛结束。",
      "speech_interval": {
        "start": 6.137,
        "end": 7.255
      }
    },
    {
      "index": 4,
      "start": 7.624,
      "end": 8.816,
      "duration": 1.192,
      "text": "操作简单到我想骂街，",
      "speech_interval": {
        "start": 7.669,
        "end": 8.746
      }
    },
    {
      "index": 5,
      "start": 9.261,
      "end": 10.545,
      "duration": 1.284,
      "text": "就把你那破小说往里头一丢，",
      "speech_interval": {
        "start": 9.306,
        "end": 10.475
      }
    },
    {
      "index": 6,
      "start": 10.857,
      "end": 12.562,
      "duration": 1.705,
      "text": "大模型就能自动接管一切推理剧情，",
      "speech_interval": {
        "start": 10.902,
        "end": 12.492
      }
    },
    {
      "index": 7,
      "start": 12.743,
      "end": 13.766,
      "duration": 1.024,
      "text": "脚本直接给你生成好，",
      "speech_interval": {
        "start": 12.788,
        "end": 13.696
      }
    },
    {
      "index": 8,
      "start": 13.921,
      "end": 15.555,
      "duration": 1.635,
      "text": "不用你费半天劲研究啥复杂提示词，",
      "speech_interval": {
        "start": 13.966,
        "end": 15.485
      }
    },
    {
      "index": 9,
      "start": 15.878,
      "end": 18.187,
      "duration": 2.309,
      "text": "不用你绞尽脑汁写什么智能分镜指令，",
      "speech_interval": {
        "start": 15.923,
        "end": 18.117
      }
    },
    {
      "index": 10,
      "start": 18.273,
      "end": 20.512,
      "duration": 2.239,
      "text": "直接给你出连贯到离谱的电影级分镜剧本。",
      "speech_interval": {
        "start": 18.318,
        "end": 20.442
      }
    },
    {
      "index": 11,
      "start": 21.167,
      "end": 21.89,
      "duration": 0.723,
      "text": "最牛逼的来了，",
      "speech_interval": {
        "start": 21.212,
        "end": 21.82
      }
    },
    {
      "index": 12,
      "start": 22.383,
      "end": 24.808,
      "duration": 2.425,
      "text": "他直接把人物不一致的千古难题给干碎了。",
      "speech_interval": {
        "start": 22.428,
        "end": 24.738
      }
    },
    {
      "index": 13,
      "start": 25.165,
      "end": 26.56,
      "duration": 1.396,
      "text": "一键出人物三视图场景，",
      "speech_interval": {
        "start": 25.21,
        "end": 26.49
      }
    },
    {
      "index": 14,
      "start": 26.994,
      "end": 27.732,
      "duration": 0.738,
      "text": "全套道具。",
      "speech_interval": {
        "start": 27.039,
        "end": 27.662
      }
    },
    {
      "index": 15,
      "start": 27.933,
      "end": 30.15,
      "duration": 2.217,
      "text": "你家主角从片头到片尾长得半毛钱，\n不带差的，",
      "speech_interval": {
        "start": 27.978,
        "end": 30.08
      }
    },
    {
      "index": 16,
      "start": 30.405,
      "end": 30.906,
      "duration": 0.501,
      "text": "想换画风，",
      "speech_interval": {
        "start": 30.45,
        "end": 30.836
      }
    },
    {
      "index": 17,
      "start": 31.085,
      "end": 31.794,
      "duration": 0.709,
      "text": "一键搞定。",
      "speech_interval": {
        "start": 31.13,
        "end": 31.724
      }
    },
    {
      "index": 18,
      "start": 31.99,
      "end": 32.511,
      "duration": 0.52,
      "text": "古风赛露露。",
      "speech_interval": {
        "start": 32.035,
        "end": 32.441
      }
    },
    {
      "index": 19,
      "start": 32.698,
      "end": 33.417,
      "duration": 0.719,
      "text": "国风3D日系动漫，",
      "speech_interval": {
        "start": 32.743,
        "end": 33.347
      }
    },
    {
      "index": 20,
      "start": 33.775,
      "end": 35.151,
      "duration": 1.375,
      "text": "啥风格都有，做完直接一键导出成片，",
      "speech_interval": {
        "start": 33.82,
        "end": 35.081
      }
    },
    {
      "index": 21,
      "start": 35.283,
      "end": 36.105,
      "duration": 0.822,
      "text": "全程云端运行，",
      "speech_interval": {
        "start": 35.328,
        "end": 36.035
      }
    },
    {
      "index": 22,
      "start": 36.271,
      "end": 37.609,
      "duration": 1.338,
      "text": "半毛钱不吃你电脑配置，",
      "speech_interval": {
        "start": 36.316,
        "end": 37.539
      }
    },
    {
      "index": 23,
      "start": 37.891,
      "end": 38.906,
      "duration": 1.015,
      "text": "就问你，",
      "speech_interval": {
        "start": 37.936,
        "end": 38.836
      }
    },
    {
      "index": 24,
      "start": 39.05,
      "end": 40.337,
      "duration": 1.287,
      "text": "这成品够不够顶？",
      "speech_interval": {
        "start": 39.095,
        "end": 40.267
      }
    },
    {
      "index": 25,
      "start": 40.541,
      "end": 40.98,
      "duration": 0.439,
      "text": "别 time",
      "speech_interval": {
        "start": 40.586,
        "end": 40.91
      }
    },
    {
      "index": 26,
      "start": 41.189,
      "end": 42.222,
      "duration": 1.034,
      "text": "追着我要工具了，",
      "speech_interval": {
        "start": 41.234,
        "end": 42.152
      }
    },
    {
      "index": 27,
      "start": 42.606,
      "end": 44.019,
      "duration": 1.413,
      "text": "我全给你们整理好了，",
      "speech_interval": {
        "start": 42.651,
        "end": 43.949
      }
    },
    {
      "index": 28,
      "start": 44.264,
      "end": 45.175,
      "duration": 0.911,
      "text": "只要是我粉丝，",
      "speech_interval": {
        "start": 44.309,
        "end": 45.105
      }
    },
    {
      "index": 29,
      "start": 45.85,
      "end": 46.895,
      "duration": 1.044,
      "text": "留下",
      "speech_interval": {
        "start": 45.895,
        "end": 46.825
      }
    },
    {
      "index": 30,
      "start": 47.147,
      "end": 48.039,
      "duration": 0.892,
      "text": "三个8，",
      "speech_interval": {
        "start": 47.192,
        "end": 47.969
      }
    },
    {
      "index": 31,
      "start": 48.393,
      "end": 49.146,
      "duration": 0.753,
      "text": "直接。",
      "speech_interval": {
        "start": 48.438,
        "end": 49.146
      }
    }
  ]
