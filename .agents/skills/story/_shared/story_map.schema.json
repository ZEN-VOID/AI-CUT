{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "story/_shared/story_map.schema.json",
  "title": "Story2026 Story Map Output Schema",
  "description": "用于 `2-Planning` 子技能串行写回 `2-Planning/全息地图.json` 的共享结构真源。保持 `content.holomap` 作为运行时兼容入口，同时把它明确视为 story_map carrier。",
  "type": "object",
  "$defs": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "skill_id",
        "module_id",
        "project_name",
        "created_at",
        "source_route",
        "template_version"
      ],
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "skill_id": {
          "type": "string"
        },
        "module_id": {
          "type": "string"
        },
        "project_name": {
          "type": "string"
        },
        "created_at": {
          "type": "string"
        },
        "source_route": {
          "type": "string"
        },
        "template_version": {
          "type": "string"
        },
        "truth_role": {
          "type": "string"
        }
      }
    },
    "gate_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "total_score",
        "max_score",
        "fail_codes",
        "repair_entry"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "PASS",
            "FAIL"
          ]
        },
        "total_score": {
          "type": "number"
        },
        "max_score": {
          "type": "number"
        },
        "fail_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "repair_entry": {
          "type": "string"
        }
      }
    },
    "execution_notes": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "design_rationale",
        "risk_notes"
      ],
      "properties": {
        "design_rationale": {
          "type": "string"
        },
        "risk_notes": {
          "type": "string"
        }
      }
    },
    "thread_entry": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "thread_id",
        "thread_type"
      ],
      "properties": {
        "thread_id": {
          "type": "string"
        },
        "thread_type": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "owned_by_pass": {
          "type": "string"
        }
      }
    },
    "string_or_string_array": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 1
        },
        {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      ]
    },
    "volume_board_entry": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "volume_ref",
        "chapter_range",
        "core_function",
        "volume_promise",
        "wave_duty",
        "entry_promise",
        "exit_hook",
        "visual_climate",
        "action_grammar",
        "mystery_mode",
        "emotional_temperature",
        "scene_materials",
        "performance_axis",
        "taboo_writeups"
      ],
      "properties": {
        "volume_ref": {
          "type": "string"
        },
        "chapter_range": {
          "type": "string"
        },
        "core_function": {
          "type": "string"
        },
        "volume_promise": {
          "type": "string"
        },
        "wave_duty": {
          "type": "string"
        },
        "entry_promise": {
          "type": "string"
        },
        "exit_hook": {
          "type": "string"
        },
        "visual_climate": {
          "$ref": "#/$defs/string_or_string_array"
        },
        "action_grammar": {
          "$ref": "#/$defs/string_or_string_array"
        },
        "mystery_mode": {
          "$ref": "#/$defs/string_or_string_array"
        },
        "emotional_temperature": {
          "$ref": "#/$defs/string_or_string_array"
        },
        "scene_materials": {
          "$ref": "#/$defs/string_or_string_array"
        },
        "performance_axis": {
          "$ref": "#/$defs/string_or_string_array"
        },
        "taboo_writeups": {
          "$ref": "#/$defs/string_or_string_array"
        }
      }
    },
    "chapter_planned_state_entry": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "chapter_promise",
        "entry_state",
        "carryover_threads",
        "expected_exit_delta",
        "character_focus",
        "relationship_focus"
      ],
      "properties": {
        "chapter_promise": {
          "type": "string"
        },
        "entry_state": {
          "type": "object",
          "additionalProperties": true
        },
        "carryover_threads": {
          "type": "array",
          "items": {}
        },
        "expected_exit_delta": {
          "type": "object",
          "additionalProperties": true
        },
        "character_focus": {
          "type": "object",
          "additionalProperties": true
        },
        "relationship_focus": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "character_roster_projection_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "character_id",
        "card_path",
        "name",
        "group",
        "primary_alignment",
        "narrative_function",
        "desire_line",
        "pressure_snapshot",
        "timeline_anchor",
        "current_growth_stage",
        "setpiece_hint",
        "planning_flags"
      ],
      "properties": {
        "character_id": {
          "type": "string"
        },
        "card_path": {
          "type": "string"
        },
        "name": {
          "type": "string"
        },
        "group": {
          "type": "string"
        },
        "primary_alignment": {
          "type": "string"
        },
        "narrative_function": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "desire_line": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "surface_goal",
            "true_desire",
            "need",
            "change_payoff"
          ],
          "properties": {
            "surface_goal": {
              "type": "string"
            },
            "true_desire": {
              "type": "string"
            },
            "need": {
              "type": "string"
            },
            "change_payoff": {
              "type": "string"
            }
          }
        },
        "pressure_snapshot": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "status",
            "active_pressure"
          ],
          "properties": {
            "status": {
              "type": "string"
            },
            "active_pressure": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "timeline_anchor": {
          "type": "object",
          "additionalProperties": true
        },
        "current_growth_stage": {
          "type": "string"
        },
        "setpiece_hint": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "highlight_moment",
            "memory_point"
          ],
          "properties": {
            "highlight_moment": {
              "type": "string"
            },
            "memory_point": {
              "type": "string"
            }
          }
        },
        "planning_flags": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "can_anchor_conflict",
            "can_anchor_mission"
          ],
          "properties": {
            "can_anchor_conflict": {
              "type": "boolean"
            },
            "can_anchor_mission": {
              "type": "boolean"
            }
          }
        }
      }
    },
    "relationship_graph_projection": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_graph_path",
        "scope",
        "node_refs",
        "edge_projections"
      ],
      "properties": {
        "source_graph_path": {
          "type": "string"
        },
        "scope": {
          "type": "string"
        },
        "node_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "edge_projections": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "edge_id",
              "source_character_id",
              "target_character_id",
              "relation_type",
              "relation_status",
              "dramatic_tension",
              "planning_hooks"
            ],
            "properties": {
              "edge_id": {
                "type": "string"
              },
              "source_character_id": {
                "type": "string"
              },
              "target_character_id": {
                "type": "string"
              },
              "relation_type": {
                "type": "string"
              },
              "relation_status": {
                "type": "string"
              },
              "dramatic_tension": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "planning_hooks": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "chapter_focus_hint",
                  "conflict_trigger",
                  "mission_dependency",
                  "turning_point_refs"
                ],
                "properties": {
                  "chapter_focus_hint": {
                    "type": "string"
                  },
                  "conflict_trigger": {
                    "type": "string"
                  },
                  "mission_dependency": {
                    "type": "string"
                  },
                  "turning_point_refs": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "chapter_board_entry": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "node_id",
        "episode_ref",
        "timeline_ref",
        "primary_space_ref",
        "active_space_refs",
        "bundled_elements",
        "planned_state"
      ],
      "properties": {
        "node_id": {
          "type": "string"
        },
        "episode_ref": {
          "type": "string"
        },
        "timeline_ref": {
          "type": "string"
        },
        "primary_space_ref": {
          "type": "string"
        },
        "active_space_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "bundled_elements": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "events",
            "conflicts",
            "missions",
            "clues",
            "foreshadows",
            "characters",
            "scenes",
            "items",
            "rule_impacts"
          ],
          "properties": {
            "events": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "conflicts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "missions": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "clues": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "foreshadows": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "characters": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "scenes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "items": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "rule_impacts": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "planned_state": {
          "$ref": "#/$defs/chapter_planned_state_entry"
        }
      }
    },
    "story_map_patch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "owned_slots",
        "patch_payload",
        "target_json_paths",
        "write_policy"
      ],
      "properties": {
        "owned_slots": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "patch_payload": {
          "type": "object",
          "additionalProperties": true
        },
        "target_json_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "write_policy": {
          "type": "string",
          "enum": [
            "progressive-commit",
            "normalize-only"
          ]
        }
      }
    },
    "planning_pass_artifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "meta",
        "content",
        "story_map_patch",
        "gate_summary",
        "execution_notes"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "story2026/planning-pass-artifact/v1"
        },
        "meta": {
          "$ref": "#/$defs/meta"
        },
        "content": {
          "type": "object",
          "additionalProperties": true
        },
        "story_map_patch": {
          "$ref": "#/$defs/story_map_patch"
        },
        "gate_summary": {
          "$ref": "#/$defs/gate_summary"
        },
        "execution_notes": {
          "$ref": "#/$defs/execution_notes"
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "schema_version",
    "meta",
    "content",
    "gate_summary",
    "execution_notes"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "story2026/story-map/v3"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "content": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "holomap"
      ],
      "properties": {
        "holomap": {
          "type": "object",
          "additionalProperties": true,
          "required": [
            "scope",
            "story_promise",
            "genre_corridor",
            "story_spine",
            "timeline_axis",
            "space_axis",
            "episode_sequence_axis",
            "character_roster_projection",
            "relationship_graph_projection",
            "volume_boards",
            "chapter_boards",
            "conflict_threads",
            "mission_threads",
            "clue_threads",
            "foreshadow_threads",
            "cross_thread_indexes",
            "actualization",
            "state_transitions",
            "navigation_rules"
          ],
          "properties": {
            "scope": {
              "type": "string"
            },
            "story_promise": {
              "type": "object",
              "additionalProperties": true
            },
            "genre_corridor": {
              "type": "object",
              "additionalProperties": true
            },
            "story_spine": {
              "type": "object",
              "additionalProperties": true
            },
            "timeline_axis": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "space_axis": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "episode_sequence_axis": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "character_roster_projection": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/character_roster_projection_entry"
              }
            },
            "relationship_graph_projection": {
              "$ref": "#/$defs/relationship_graph_projection"
            },
            "volume_boards": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/volume_board_entry"
              }
            },
            "chapter_boards": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/chapter_board_entry"
              }
            },
            "conflict_threads": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/thread_entry"
              }
            },
            "mission_threads": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/thread_entry"
              }
            },
            "clue_threads": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/thread_entry"
              }
            },
            "foreshadow_threads": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/thread_entry"
              }
            },
            "lifecycle_lexicon": {
              "type": "object",
              "additionalProperties": true
            },
            "cross_thread_indexes": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "actualization": {
              "type": "object",
              "additionalProperties": true
            },
            "state_transitions": {
              "type": "array",
              "items": {
                "type": "object"
              }
            },
            "navigation_rules": {
              "type": "array",
              "items": {
                "type": "object"
              }
            }
          }
        }
      }
    },
    "gate_summary": {
      "$ref": "#/$defs/gate_summary"
    },
    "execution_notes": {
      "$ref": "#/$defs/execution_notes"
    }
  }
}
