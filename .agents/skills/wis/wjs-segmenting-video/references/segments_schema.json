{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "video-segmentation segments.json",
  "type": "object",
  "required": ["source_video", "segments"],
  "properties": {
    "source_video": {
      "type": "string",
      "description": "path to the source video, relative to segments.json"
    },
    "source_srt": {
      "type": "string",
      "description": "optional path to the source SRT used to pick boundaries"
    },
    "platform": {
      "type": "string",
      "enum": ["wechat_channels", "douyin", "xiaohongshu", "shorts", "reels"],
      "default": "wechat_channels"
    },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "slug", "title", "start", "end"],
        "properties": {
          "id": {"type": "integer", "minimum": 1},
          "slug": {
            "type": "string",
            "pattern": "^[a-z0-9-]+$",
            "description": "kebab-case English; used in filenames"
          },
          "title": {
            "type": "string",
            "description": "cover title; use \\n for line breaks; aim for 8-12 Chinese chars per line, 2 lines max"
          },
          "summary": {"type": "string"},
          "start": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}:\\d{2}[,.]\\d{1,3}$",
            "description": "HH:MM:SS.mmm or HH:MM:SS,mmm; must align to an SRT cue boundary"
          },
          "end": {
            "type": "string",
            "pattern": "^\\d{2}:\\d{2}:\\d{2}[,.]\\d{1,3}$"
          },
          "cover_prompt": {
            "type": "string",
            "description": "passed to gpt-image-2 along with a real frame as ref-image; describe visual concept, not literal scene; ALWAYS include 'no text' in your wrapper prompt to suppress hallucinated glyphs"
          }
        }
      }
    }
  }
}
