{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aigc/_shared/director_episode_output.schema.json",
  "title": "AIGC Director Episode Output Schema",
  "description": "用于 `1-Planning/3-分组 -> 2-Global -> 3-Detail` 的共享 JSON 输出真源。当前 canonical 输出按 `metadata / final_output` 双槽组织；`thinking_chain` 仅为兼容旧 root 的可选摘要槽，默认不输出。",
  "type": "object",
  "allOf": [
    {
      "if": {
        "properties": {
          "metadata": {
            "properties": {
              "document_phase": {
                "enum": [
                  "detail_in_progress",
                  "ready"
                ]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "final_output": {
            "properties": {
              "main_content": {
                "properties": {
                  "分镜组列表": {
                    "items": {
                      "properties": {
                        "分镜明细": {
                          "minItems": 1
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "metadata": {
            "properties": {
              "document_phase": {
                "const": "directing_in_progress"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "final_output": {
            "properties": {
              "main_content": {
                "properties": {
                  "分镜组列表": {
                    "items": {
                      "properties": {
                        "组间设计": {
                          "properties": {
                            "全局风格": {
                              "maxLength": 220
                            },
                            "类型元素": {
                              "maxLength": 50
                            },
                            "导演意图": {
                              "maxLength": 100
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false,
  "required": [
    "metadata",
    "final_output"
  ],
  "properties": {
    "metadata": {
      "title": "元数据",
      "description": "声明本次导演集级结构化产物的识别、路由和追踪字段。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "skill_id",
        "template_version",
        "source_route",
        "episode_id",
        "document_phase",
        "created_at"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "aigc/director-episode-output/v1"
        },
        "skill_id": {
          "type": "string",
          "description": "生成本结构化产物的主技能标识。"
        },
        "template_version": {
          "type": "string",
          "description": "当前模板版本。"
        },
        "source_route": {
          "type": "string",
          "description": "上游来源或执行路由，例如 `2-Global/导演意图 -> 3-Detail`。"
        },
        "source_profile": {
          "type": "object",
          "description": "上游故事源类型及预设保护模式，供 `3-Detail` 读取。",
          "additionalProperties": false,
          "required": [
            "source_type",
            "preset_retention_mode",
            "detail_expansion_mode",
            "locked_preset_axes",
            "preset_registry"
          ],
          "properties": {
            "source_type": {
              "type": "string",
              "enum": [
                "novel_original",
                "script_original",
                "storyboard_script",
                "oral_story_transcript",
                "hybrid_story_text"
              ]
            },
            "preset_retention_mode": {
              "type": "string",
              "enum": [
                "standard",
                "preserve_and_extend",
                "preserve_only"
              ]
            },
            "detail_expansion_mode": {
              "type": "string",
              "enum": [
                "free_expansion",
                "guided_expansion",
                "respect_storyboard_presets"
              ]
            },
            "locked_preset_axes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "preset_registry": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/preset_anchor"
              }
            }
          }
        },
        "episode_id": {
          "type": "string",
          "description": "集标识，例如 `第1集`。"
        },
        "document_phase": {
          "type": "string",
          "enum": [
            "bootstrapped",
            "planning_seeded",
            "directing_in_progress",
            "detail_in_progress",
            "ready"
          ],
          "description": "当前文档所处的生命周期阶段。"
        },
        "created_at": {
          "type": "string",
          "description": "ISO 8601 时间戳。"
        }
      }
    },
    "thinking_chain": {
      "title": "思维链",
      "description": "兼容旧 root 的可选摘要槽；默认不输出，也不作为阶段写回或验收必填项。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "thinking_goal",
        "key_steps",
        "conclusion"
      ],
      "properties": {
        "thinking_goal": {
          "type": "string"
        },
        "key_steps": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "#/$defs/thinking_step"
          }
        },
        "conclusion": {
          "type": "string"
        }
      }
    },
    "final_output": {
      "title": "主内容",
      "description": "真正交给下游阶段消费的导演集级结构化内容。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deliverable_type",
        "main_content",
        "acceptance_notes"
      ],
      "properties": {
        "deliverable_type": {
          "type": "string",
          "const": "director_episode_output"
        },
        "main_content": {
          "title": "主内容",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "分镜组列表"
          ],
          "properties": {
            "分镜组列表": {
              "type": "array",
              "minItems": 0,
              "items": {
                "$ref": "#/$defs/storyboard_group"
              }
            }
          }
        },
        "acceptance_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "thinking_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "focus",
        "evidence",
        "judgment"
      ],
      "properties": {
        "step_id": {
          "type": "string"
        },
        "focus": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        },
        "judgment": {
          "type": "string"
        }
      }
    },
    "preset_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "anchor_id",
        "source_span",
        "lock_level",
        "owned_axes",
        "expandable_axes",
        "forbidden_changes",
        "projected_group_ids",
        "projected_shot_mode"
      ],
      "properties": {
        "anchor_id": {
          "type": "string"
        },
        "source_span": {
          "type": "string"
        },
        "lock_level": {
          "type": "string",
          "enum": [
            "hard_lock",
            "soft_lock",
            "reference_only"
          ]
        },
        "owned_axes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expandable_axes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_changes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "projected_group_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "projected_shot_mode": {
          "type": "string",
          "enum": [
            "single_anchor_single_shot",
            "single_anchor_multi_shot",
            "multi_anchor_fixed",
            "reference_only"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "storyboard_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "分镜组ID",
        "总时长",
        "剧本正文",
        "组间设计",
        "分镜切换",
        "分镜明细"
      ],
      "properties": {
        "分镜组ID": {
          "type": "string"
        },
        "总时长": {
          "type": "number",
          "minimum": 0,
          "description": "单位：秒；表示当前分镜组的 canonical 总时长，也是该组相对时间轴的上界。"
        },
        "剧本正文": {
          "type": "string",
          "description": "该分镜组在 `1-Planning/3-分组/第N集.md` 中的完整正文整理结果；除重复组号标题外不得摘要化。"
        },
        "组间设计": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "全局风格",
            "类型元素",
            "导演意图",
            "出场角色及穿搭"
          ],
          "properties": {
            "全局风格": {
              "type": "string",
              "description": "由 2-Global 直接引用 `全局风格/全局风格设计.md` 中字段标题 `全局风格` 的项目级无污染统一风格前缀，默认不超过 220 字。"
            },
            "类型元素": {
              "type": "string",
              "description": "由 2-Global 直接引用 `类型元素/分组设计.md` 中命中组字段标题 `类型元素` 的组级类型信号，默认不超过 50 字。"
            },
            "导演意图": {
              "type": "string",
              "description": "由 2-Global 直接引用 `设计元素/设计元素.md` 中命中组字段标题 `导演意图` 的组级执行导向，默认不超过 100 字。"
            },
            "出场角色及穿搭": {
              "type": "string",
              "description": "组级角色服装摘要槽；格式建议为 `角色名-服装简述`，多个角色用 `；` 分隔。`2-Global` 可先留空字符串占位，`3-Detail` 在镜级明细稳定后应回填。"
            }
          }
        },
        "分镜切换": {
          "type": "integer",
          "minimum": 1,
          "description": "由 `2-Global` 在阶段末段直接写入的组级固定分镜数。它是该组后续 `3-Detail` 落镜时必须接受的总导演真值，不再在 `水月` 或 `镜花` 内重判。"
        },
        "分镜明细": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "#/$defs/shot_detail"
          }
        }
      }
    },
    "shot_detail": {
      "type": "object",
      "description": "镜级 final factual 槽位。`3-Detail/水月` 先产 beat-level factual evidence，`镜花` 再基于既定 `分镜切换 + beat_refs[]` 落出 shot skeleton；父层将两者合成为这些 canonical 字段，不得把内部链名直接投影为并列输出字段。",
      "additionalProperties": false,
      "required": [
        "分镜ID",
        "时间段",
        "角色背景面",
        "角色站位走位",
        "道具及状态",
        "分镜表现",
        "运镜手法",
        "摄影美学"
      ],
      "properties": {
        "分镜ID": {
          "type": "string"
        },
        "时间段": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "开始秒",
            "结束秒"
          ],
          "properties": {
            "开始秒": {
              "type": "number",
              "minimum": 0,
              "description": "当前分镜组内的相对开始秒位；组内首镜通常从 0 开始，不使用全集累积时间。"
            },
            "结束秒": {
              "type": "number",
              "minimum": 0,
              "description": "当前分镜组内的相对结束秒位；最后一镜的结束秒通常应与所在组 `总时长` 对齐。"
            }
          },
          "description": "以秒为单位的组内相对闭区间；时间零点以当前分镜组起点为准，不得写成全集累积时间线。"
        },
        "角色背景面": {
          "type": "string",
          "description": "在角色中心主义下，交代当前镜头作为角色背景的具体场景方位面，例如东西南北面、入口/出口、内外侧或墙面/尽头关系。"
        },
        "角色站位走位": {
          "type": "string",
          "description": "明确角色在镜头中的当前位置、相对层次与位移路径，要求包含走位/移位信息，不只写静态站位。服装信息默认上收至 `组间设计.出场角色及穿搭`。"
        },
        "道具及状态": {
          "type": "string"
        },
        "分镜表现": {
          "type": "string",
          "description": "镜级最终视觉抓手槽；只保留可被镜头直接消费的结果，不回显内部分析链名或并列思考维度。"
        },
        "景别": {
          "type": "string",
          "description": "可选镜头描述子槽；例如 `中景`、`近景`、`特写`。示例值仅用于说明字段形状，不代表默认推荐值。"
        },
        "镜头属性": {
          "type": "string",
          "description": "可选镜头描述子槽；例如 `定场镜头`、`关系建立镜头`、`反应镜头`。示例值仅用于说明字段形状，不代表默认推荐值。"
        },
        "镜头框架": {
          "type": "string",
          "description": "可选镜头描述子槽；压缩主体/陪体/背景关系与构图结果。示例值仅用于说明字段形状，不代表默认推荐值。"
        },
        "镜头类型": {
          "type": "string",
          "description": "可选镜头描述子槽；说明当前镜头在叙事链中的职责。示例值仅用于说明字段形状，不代表默认推荐值。"
        },
        "镜头视角": {
          "type": "string",
          "description": "可选镜头描述子槽；例如 `平视`、`俯视`、`仰视`、`过肩视角`。示例值仅用于说明字段形状，不代表默认推荐值。"
        },
        "运镜手法": {
          "type": "string"
        },
        "镜头速度": {
          "type": "string",
          "description": "可选镜头运动速度槽；用于把运动路线与速度档分离，例如 `慢速压近`、`中速跟随`、`急停后极慢收束`。旧数据允许缺省，新数据若填写应与 `运镜手法` 保持一致。"
        },
        "摄影美学": {
          "type": "string"
        },
        "转场特效": {
          "type": "string",
          "description": "非必须；仅在该镜头需要显式转场或特效桥接时填写。"
        }
      }
    },
    "detail_patch_sidecar": {
      "type": "object",
      "description": "`3-Detail` 子技能 sidecar 投影定义。唯一真源已收束到当前 schema：`水月` 负责 group/beat factual evidence，`镜花` 负责 shot skeleton 与 cinematic patch；父层负责 merge 回 canonical `final_output.main_content.分镜组列表[]`。",
      "additionalProperties": false,
      "required": [
        "metadata",
        "group_patches"
      ],
      "properties": {
        "metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "skill_id",
            "episode_id",
            "patch_owner",
            "source_root",
            "script_body_policy",
            "generated_at"
          ],
          "properties": {
            "schema_version": {
              "type": "string",
              "const": "aigc/detail-patch-sidecar/v1"
            },
            "skill_id": {
              "type": "string"
            },
            "episode_id": {
              "type": "string"
            },
            "patch_owner": {
              "type": "string",
              "enum": [
                "水月",
                "镜花"
              ]
            },
            "source_root": {
              "type": "string"
            },
            "script_body_policy": {
              "type": "string",
              "const": "inherit_only"
            },
            "generated_at": {
              "type": "string"
            }
          }
        },
        "group_patches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/detail_group_patch"
          }
        }
      }
    },
    "detail_group_patch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group_id",
        "target_fields"
      ],
      "properties": {
        "group_id": {
          "type": "string"
        },
        "target_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "group_design_patch": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "出场角色及穿搭": {
              "type": "string"
            }
          }
        },
        "beat_patches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/detail_beat_patch"
          }
        },
        "shot_patches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/detail_shot_patch"
          }
        },
        "merge_hints": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "detail_beat_patch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "beat_id",
        "anchor_summary",
        "角色背景面",
        "角色站位走位",
        "道具及状态",
        "镜头消费提示"
      ],
      "properties": {
        "beat_id": {
          "type": "string"
        },
        "anchor_summary": {
          "type": "string"
        },
        "角色背景面": {
          "type": "string"
        },
        "角色站位走位": {
          "type": "string"
        },
        "道具及状态": {
          "type": "string"
        },
        "镜头消费提示": {
          "type": "string"
        }
      }
    },
    "detail_shot_patch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "slot_id",
        "分镜ID",
        "beat_refs",
        "时间段",
        "景别",
        "镜头属性",
        "镜头框架",
        "镜头类型",
        "镜头视角",
        "运镜手法",
        "摄影美学"
      ],
      "properties": {
        "slot_id": {
          "type": "string"
        },
        "分镜ID": {
          "type": "string"
        },
        "beat_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "时间段": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "开始秒",
            "结束秒"
          ],
          "properties": {
            "开始秒": {
              "type": "number",
              "minimum": 0
            },
            "结束秒": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "景别": {
          "type": "string"
        },
        "镜头属性": {
          "type": "string"
        },
        "镜头框架": {
          "type": "string"
        },
        "镜头类型": {
          "type": "string"
        },
        "镜头视角": {
          "type": "string"
        },
        "运镜手法": {
          "type": "string"
        },
        "镜头速度": {
          "type": "string"
        },
        "摄影美学": {
          "type": "string"
        },
        "转场特效": {
          "type": "string"
        }
      }
    }
  },
  "examples": [
    {
      "metadata": {
        "schema_version": "aigc/director-episode-output/v1",
        "skill_id": "aigc-global",
        "template_version": "global-seed-v1",
        "source_route": "2-Global group_design seed",
        "episode_id": "第1集",
        "document_phase": "directing_in_progress",
        "created_at": "2026-04-12T10:00:00-07:00"
      },
      "final_output": {
        "deliverable_type": "director_episode_output",
        "main_content": {
          "分镜组列表": [
            {
              "分镜组ID": "1-1-1",
              "总时长": 18,
              "剧本正文": "角色A推门进入空旷长廊，角色B在尽头停住脚步。",
              "组间设计": {
                "全局风格": "低照度心理悬疑影视风格，低调照明、空气介质交互与胶片化质感统一，整体维持遮蔽、压抑、延迟揭示的不安基调。",
                "类型元素": "悬疑压迫优先，克制抒情。",
                "出场角色及穿搭": ""
              },
              "分镜切换": 3,
              "分镜明细": []
            }
          ]
        },
