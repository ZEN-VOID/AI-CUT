{
  "schema": "skill-manifest/v1",
  "skill_id": "aigc.design.scene_design",
  "skill_path": ".agents/skills/aigc/5-设计/2-设计/场景",
  "io": {
    "inputs": {
      "scene_catalog": {
        "pattern": "projects/aigc/<项目名>/4-设计/场景/1-清单/第{episode}集/场景清单.json",
        "format": "json",
        "required": true,
        "required_fields": [
          "scenes",
          "scenes[].scene_id",
          "scenes[].scene_name"
        ]
      },
      "scene_research": {
        "pattern": "projects/aigc/<项目名>/4-设计/场景/1-清单/第{episode}集/场景研究.json",
        "format": "json",
        "required": false
      },
      "scene_bridge": {
        "pattern": "projects/aigc/<项目名>/4-设计/场景/1-清单/第{episode}集/scene_design_bridge.json",
        "format": "json",
        "required": false
      },
      "north_star": {
        "pattern": "projects/aigc/<项目名>/0-Init/north_star.yaml",
        "format": "yaml",
        "required": false
      },
      "global_style": {
        "pattern": "projects/aigc/<项目名>/2-Global/全局风格.md",
        "format": "markdown",
        "required": false
      }
    },
    "outputs": {
      "primary": {
        "pattern": "projects/aigc/<项目名>/4-设计/场景/2-设计/第{episode}集/scene_design.json",
        "format": "json",
        "required_fields": [
          "scenes",
          "scenes[].scene_id",
          "scenes[].structured_fields",
          "scenes[].design_prompt",
          "scenes[].global_style_prefix",
          "scenes[].full_generation_prompt",
          "scenes[].final_prompt"
        ]
      },
      "auto_image_assets": {
        "pattern": "projects/aigc/<项目名>/4-设计/场景/2-设计/第{episode}集/*.{png,jpg,jpeg,webp}",
        "format": "image",
        "naming": "same_stem_as_human_projection"
      },
      "manifest": {
        "pattern": "projects/aigc/<项目名>/4-设计/场景/2-设计/第{episode}集/_manifest.json",
        "format": "json"
      },
      "human_projection_dir": {
        "pattern": "projects/aigc/<项目名>/4-设计/场景/2-设计/第{episode}集/",
        "format": "directory"
      }
    }
  },
  "dependencies": {
    "requires": [
      "aigc.design.scene_list"
    ],
    "optional_context": [
      "aigc-global",
      "aigc-init"
    ]
  },
  "scope": "episode",
  "tags": [
    "aigc",
    "design",
    "scene",
    "prompt"
  ]
}
