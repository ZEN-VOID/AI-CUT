{
  "schema": "skill-manifest/v1",
  "skill_id": "design.role_list",
  "skill_path": ".agents/skills/aigc/5-设计/1-清单/角色",
  "io": {
    "inputs": {
      "source": {
        "pattern": "projects/aigc/<项目名>/3-Detail/第{episode}集.json",
        "format": "json",
        "required": true
      }
    },
    "outputs": {
      "role_list": {
        "pattern": "projects/aigc/<项目名>/4-设计/角色/1-清单/第{episode}集/角色清单.json",
        "format": "json"
      },
      "role_research": {
        "pattern": "projects/aigc/<项目名>/4-设计/角色/1-清单/第{episode}集/角色研究.json",
        "format": "json"
      },
      "role_bridge": {
        "pattern": "projects/aigc/<项目名>/4-设计/角色/1-清单/第{episode}集/role_design_bridge.json",
        "format": "json",
        "required_fields": [
          "roles",
          "roles[].design_bridge_profile"
        ]
      },
      "report": {
        "pattern": "projects/aigc/<项目名>/4-设计/角色/1-清单/第{episode}集/validation-report.md",
        "format": "markdown"
      },
      "manifest": {
        "pattern": "projects/aigc/<项目名>/4-设计/角色/1-清单/第{episode}集/_manifest.json",
        "format": "json",
        "optional": true
      }
    }
  },
  "dependencies": {
    "requires": [
      "aigc-detail"
    ],
    "optional_context": [
      "aigc-global"
    ]
  },
  "scope": "episode",
  "tags": [
    "design",
    "role",
    "list",
    "detail-consumption"
  ]
}
