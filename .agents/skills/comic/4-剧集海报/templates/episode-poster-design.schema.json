{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "comic_episode_poster_design.v1",
  "type": "object",
  "required": [
    "schema_version",
    "project_name",
    "type_stack_ref",
    "type_pack_context",
    "episode",
    "upstream_context",
    "thinking_process",
    "creative_direction",
    "subject_lock",
    "composition",
    "text_system",
    "atmosphere_color",
    "prompt_package",
    "imagegen_handoff"
  ],
  "properties": {
    "schema_version": {
      "const": "comic_episode_poster_design.v1"
    },
    "project_name": {
      "type": "string",
      "minLength": 1
    },
    "type_stack_ref": {
      "type": "object",
      "required": ["method_kernel", "base", "primary", "active_packs"],
      "properties": {
        "method_kernel": {"const": "comic-core-v1"},
        "base": {"type": "string"},
        "primary": {"type": "string"},
        "secondary": {"type": "array", "items": {"type": "string"}},
        "platform": {"type": "array", "items": {"type": "string"}},
        "audience": {"type": "array", "items": {"type": "string"}},
        "active_packs": {"type": "array", "minItems": 2, "items": {"type": "string"}}
      }
    },
    "type_pack_context": {
      "type": "object",
      "required": ["resolution_mode", "knowledge_refs", "semantic_tags", "stage_projection", "control_surface"],
      "properties": {
        "resolution_mode": {"type": "string"},
        "knowledge_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "knowledge_digest": {"type": "array", "items": {"type": "string"}},
        "control_surface_digest": {"type": "array", "items": {"type": "string"}},
        "semantic_tags": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "projection_summary": {"type": "object"},
        "control_surface": {
          "type": "object",
          "required": ["conflict_engine", "role_matrix", "page_turn_mechanism", "panel_grammar", "visual_carrier", "dialogue_register", "motif_system", "failure_modes"],
          "properties": {
            "conflict_engine": {"type": "object"},
            "role_matrix": {"type": "object"},
            "page_turn_mechanism": {"type": "object"},
            "panel_grammar": {"type": "object"},
            "visual_carrier": {"type": "object"},
            "dialogue_register": {"type": "object"},
            "motif_system": {"type": "object"},
            "failure_modes": {"type": "array", "items": {"type": ["string", "object"]}}
          }
        },
        "stage_projection": {
          "type": "object",
          "required": ["script_adaptation", "nine_blade_prompting", "image_generation", "animation_generation", "episode_poster"],
          "properties": {
            "script_adaptation": {"type": "object"},
            "nine_blade_prompting": {"type": "object"},
            "image_generation": {"type": "object"},
            "animation_generation": {"type": "object"},
            "episode_poster": {"type": "object"}
          }
        }
      }
    },
    "episode": {
      "type": "object",
      "required": [
        "number",
        "display_text"
      ],
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "display_text": {
          "type": "string",
          "pattern": "^第\\d+集$"
        }
      }
    },
    "upstream_context": {
      "type": "object",
      "required": [
        "loaded_artifacts",
        "style_inheritance",
        "highlight_discovery"
      ]
    },
    "thinking_process": {
      "type": "object"
    },
    "creative_direction": {
      "type": "object",
      "required": [
        "creative_core",
        "representative_scene",
        "hook_meaning"
      ]
    },
    "subject_lock": {
      "type": "object",
      "required": [
        "only_current_episode_characters",
        "primary_subjects"
      ]
    },
    "composition": {
      "type": "object",
      "required": [
        "aspect_ratio",
        "foreground",
        "subjects",
        "background"
      ]
    },
    "text_system": {
      "type": "object",
      "required": [
        "horizontal_alignment",
        "vertical_alignment",
        "episode_label",
        "hook_title"
      ]
    },
    "atmosphere_color": {
      "type": "object",
      "required": [
        "mood",
        "dominant_colors",
        "accent_colors",
        "lighting_strategy"
      ]
    },
    "prompt_package": {
      "type": "object",
      "required": [
        "positive_prompt",
        "negative_prompt"
      ]
    },
    "imagegen_handoff": {
      "type": "object",
      "required": [
        "tool_skill_path",
        "render_prompt_source",
        "suggested_output_dir",
        "mode_policy",
        "persist_policy"
      ],
      "properties": {
        "tool_skill_path": {
          "const": ".agents/skills/cli/imagegen"
        },
        "render_prompt_source": {
          "const": "prompt_package.positive_prompt"
        },
        "suggested_output_dir": {
          "type": "string",
          "minLength": 1
        },
        "mode_policy": {
          "type": "string",
          "minLength": 1
        },
        "persist_policy": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
