{
  "schema": "skill-manifest/v1",
  "skill_id": "planning",
  "skill_path": ".agents/skills/aigc/1-规划",
  "modes": {
    "episode_split": {
      "reference": ".agents/skills/aigc/1-规划/references/episode-splitter-contract.md",
      "template": ".agents/skills/aigc/1-规划/templates/episode-split-plan.template.json"
    },
    "script_format": {
      "display_name": "2-剧本",
      "runtime_path_alias": "2-格式",
      "reference": ".agents/skills/aigc/1-规划/references/script-format-contract.md",
      "report_template": ".agents/skills/aigc/1-规划/templates/script-format-report.template.md",
      "validator": ".agents/skills/aigc/1-规划/scripts/validate_script_output.py"
    },
    "grouping": {
      "reference": ".agents/skills/aigc/1-规划/references/grouping-contract.md",
      "postprocess": ".agents/skills/aigc/1-规划/scripts/postprocess_grouping_output.py",
      "quantizer": ".agents/skills/aigc/1-规划/scripts/grouping_quantizer.py",
      "validator": ".agents/skills/aigc/1-规划/scripts/validate_grouping_output.py"
    }
  },
  "postprocess": {
    "grouping": {
      "script": ".agents/skills/aigc/1-规划/scripts/postprocess_grouping_output.py",
      "runner": "python3",
      "args": [
        {
          "flag": "--input",
          "value": "{output_path}"
        }
      ]
    }
  },
  "io": {
    "inputs": {
      "story_source": {
        "pattern": "projects/aigc/<项目名>/Story/",
        "format": "directory",
        "required_for": ["episode_split"]
      },
      "split_source": {
        "pattern": "projects/aigc/<项目名>/1-Planning/1-分集/第{episode}.md",
        "format": "markdown",
        "required_for": ["script_format"]
      },
      "formatted_script": {
        "pattern": "projects/aigc/<项目名>/1-Planning/2-格式/第{episode}.md",
        "format": "markdown",
        "required_for": ["grouping"]
      }
    },
    "outputs": {
      "episode_split": {
        "pattern": "projects/aigc/<项目名>/1-Planning/1-分集/第{episode}.md",
        "format": "markdown"
      },
      "script_format": {
        "pattern": "projects/aigc/<项目名>/1-Planning/2-格式/第{episode}.md",
        "format": "markdown"
      },
      "script_format_report": {
        "pattern": "projects/aigc/<项目名>/1-Planning/2-格式/执行报告.md",
        "format": "markdown"
      },
      "grouping": {
        "pattern": "projects/aigc/<项目名>/1-Planning/3-分组/第{episode}.md",
        "format": "markdown",
        "required_sections": ["【分组正文】"]
      },
      "stage_validation": {
        "pattern": "projects/aigc/<项目名>/1-Planning/validation-report.md",
        "format": "markdown"
      }
    }
  },
  "scope": "stage",
  "tags": ["planning", "episode_split", "script_format", "grouping", "skill2"]
}
