{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aigc/_shared/director_episode_output.schema.json",
  "title": "AIGC Director Episode Output Schema",
  "description": "用于 `1-Planning/3-分组 -> 2-Global -> 3-Detail` 的共享 JSON 输出真源。当前 canonical 输出按 `metadata / final_output` 双槽组织；`thinking_chain` 仅为兼容旧 root 的可选摘要槽，默认不输出。",
  "type": "object",
  "allOf": [
    {
      "if": {
        "properties": {
          "metadata": {
            "properties": {
              "document_phase": {
                "enum": [
                  "detail_in_progress",
                  "ready"
                ]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "final_output": {
            "properties": {
              "main_content": {
                "properties": {
                  "分镜组列表": {
                    "items": {
                      "required": [
                        "正文切分参考"
                      ],
                      "properties": {
                        "正文切分参考": {
                          "minItems": 1
                        },
                        "分镜明细": {
                          "minItems": 1,
                          "items": {
                            "required": [
                              "正文回指"
                            ],
                            "properties": {
                              "正文回指": {
                                "required": [
                                  "beat_refs",
                                  "coverage_mode"
                                ],
                                "properties": {
                                  "beat_refs": {
                                    "minItems": 1
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "metadata": {
            "properties": {
              "document_phase": {
                "const": "directing_in_progress"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "final_output": {
            "properties": {
              "main_content": {
                "properties": {
                  "分镜组列表": {
                    "items": {
                      "properties": {
                        "组间设计": {
                          "properties": {
                            "全局风格": {
                              "maxLength": 220
                            },
                            "类型元素": {
                              "maxLength": 50
                            },
                            "导演意图": {
                              "maxLength": 100
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false,
  "required": [
    "metadata",
    "final_output"
  ],
  "properties": {
    "metadata": {
      "title": "元数据",
      "description": "声明本次导演集级结构化产物的识别、路由和追踪字段。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "skill_id",
        "template_version",
        "source_route",
        "episode_id",
        "document_phase",
        "created_at"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "aigc/director-episode-output/v1"
        },
        "skill_id": {
          "type": "string",
          "description": "生成本结构化产物的主技能标识。"
        },
        "template_version": {
          "type": "string",
          "description": "当前模板版本。"
        },
        "source_route": {
          "type": "string",
          "description": "上游来源或执行路由，例如 `2-Global/导演意图 -> 3-Detail`。"
        },
        "source_profile": {
          "type": "object",
          "description": "上游故事源类型及预设保护模式，供 `3-Detail` 读取。",
          "additionalProperties": false,
          "required": [
            "source_type",
            "preset_retention_mode",
            "detail_expansion_mode",
            "locked_preset_axes",
            "preset_registry"
          ],
          "properties": {
            "source_type": {
              "type": "string",
              "enum": [
                "novel_original",
                "script_original",
                "storyboard_script",
                "oral_story_transcript",
                "hybrid_story_text"
              ]
            },
            "preset_retention_mode": {
              "type": "string",
              "enum": [
                "standard",
                "preserve_and_extend",
                "preserve_only"
              ]
            },
            "detail_expansion_mode": {
              "type": "string",
              "enum": [
                "free_expansion",
                "guided_expansion",
                "respect_storyboard_presets"
              ]
            },
            "locked_preset_axes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "preset_registry": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/preset_anchor"
              }
            }
          }
        },
        "episode_id": {
          "type": "string",
          "description": "集标识，例如 `第1集`。"
        },
        "document_phase": {
          "type": "string",
          "enum": [
            "bootstrapped",
            "planning_seeded",
            "directing_in_progress",
            "detail_in_progress",
            "ready"
          ],
          "description": "当前文档所处的生命周期阶段。"
        },
        "created_at": {
          "type": "string",
          "description": "ISO 8601 时间戳。"
        }
      }
    },
    "thinking_chain": {
      "title": "思维链",
      "description": "兼容旧 root 的可选摘要槽；默认不输出，也不作为阶段写回或验收必填项。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "thinking_goal",
        "key_steps",
        "conclusion"
      ],
      "properties": {
        "thinking_goal": {
          "type": "string"
        },
        "key_steps": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "#/$defs/thinking_step"
          }
        },
        "conclusion": {
          "type": "string"
        }
      }
    },
    "final_output": {
      "title": "主内容",
      "description": "真正交给下游阶段消费的导演集级结构化内容。",
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deliverable_type",
        "main_content",
        "acceptance_notes"
      ],
      "properties": {
        "deliverable_type": {
          "type": "string",
          "const": "director_episode_output"
        },
        "main_content": {
          "title": "主内容",
          "type": "object",
          "additionalProperties": false,
          "required": [
            "分镜组列表"
          ],
          "properties": {
            "分镜组列表": {
              "type": "array",
              "minItems": 0,
              "items": {
                "$ref": "#/$defs/storyboard_group"
              }
            }
          }
        },
        "acceptance_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "thinking_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "focus",
        "evidence",
        "judgment"
      ],
      "properties": {
        "step_id": {
          "type": "string"
        },
        "focus": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        },
        "judgment": {
          "type": "string"
        }
      }
    },
    "preset_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "anchor_id",
        "source_span",
        "lock_level",
        "owned_axes",
        "expandable_axes",
        "forbidden_changes",
        "projected_group_ids",
        "projected_shot_mode"
      ],
      "properties": {
        "anchor_id": {
          "type": "string"
        },
        "source_span": {
          "type": "string"
        },
        "lock_level": {
          "type": "string",
          "enum": [
            "hard_lock",
            "soft_lock",
            "reference_only"
          ]
        },
        "owned_axes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expandable_axes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_changes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "projected_group_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "projected_shot_mode": {
          "type": "string",
          "enum": [
            "single_anchor_single_shot",
            "single_anchor_multi_shot",
            "multi_anchor_fixed",
            "reference_only"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "storyboard_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "分镜组ID",
        "总时长",
        "剧本正文",
        "组间设计",
        "分镜切换",
        "分镜明细"
      ],
      "properties": {
        "分镜组ID": {
          "type": "string"
        },
        "总时长": {
          "type": "number",
          "minimum": 0,
          "description": "单位：秒；表示当前分镜组的 canonical 总时长，也是该组相对时间轴的上界。"
        },
        "剧本正文": {
          "type": "string",
          "description": "该分镜组在 `1-Planning/3-分组/第N集.md` 中的完整正文整理结果；除重复组号标题外不得摘要化。"
        },
        "正文切分参考": {
          "type": "array",
          "description": "由 `3-Detail` 在继承整组 `剧本正文` 后补出的正文切分真源。每条切分都以 `beat_id` 稳定编号，保留完整原文片段与字符范围，供镜级 `正文回指` 统一回链；不得把同一段原文重复复制到每条 `分镜明细` 里作为第二真源。",
          "items": {
            "$ref": "#/$defs/script_segment_reference"
          }
        },
        "组间设计": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "全局风格",
            "类型元素",
            "导演意图",
            "出场角色及穿搭"
          ],
          "properties": {
            "全局风格": {
              "type": "string",
              "description": "由 2-Global 直接引用 `全局风格.md` 中字段标题 `全局风格` 的项目级无污染统一风格前缀，默认不超过 220 字。"
            },
            "类型元素": {
              "type": "string",
              "description": "由 2-Global 直接引用 `分组类型元素.md` 中命中组字段标题 `类型元素` 的组级类型信号，默认不超过 50 字。"
            },
            "导演意图": {
              "type": "string",
              "description": "由 2-Global 直接引用 `导演意图.md` 中命中组字段标题 `导演意图` 的组级执行导向，默认不超过 100 字。"
            },
            "出场角色及穿搭": {
              "type": "string",
              "description": "组级角色服装摘要槽；格式建议为 `角色名-服装简述`，多个角色用 `；` 分隔。`2-Global` 可先留空字符串占位，`3-Detail` 在镜级明细稳定后应回填。"
            }
          }
        },
        "分镜切换": {
          "type": "integer",
          "minimum": 1,
          "description": "由 `2-Global` 在阶段末段根据总时长、媒介形态、平台形态、类型任务与组正文直接写入的组级固定分镜数。它是该组后续 `3-Detail` 落镜时必须接受的总导演真值，不再在 `水月` 或 `镜花` 内重判。"
        },
        "分镜明细": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "#/$defs/shot_detail"
          }
        }
      }
    },
    "script_segment_char_range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "type": "integer",
          "minimum": 0,
          "description": "在 `分镜组.剧本正文` 中的起始字符位置，0-based，inclusive。"
        },
        "end": {
          "type": "integer",
          "minimum": 1,
          "description": "在 `分镜组.剧本正文` 中的结束字符位置，0-based，exclusive。"
        }
      },
      "description": "正文切分片段的字符范围。推荐使用 `script_body[start:end] == 原文片段` 的精确回链语义。"
    },
    "script_segment_reference": {
      "type": "object",
      "description": "组级正文切分参考。它是 `剧本正文` 与 `分镜明细` 之间的唯一桥接层：先把整组正文拆为稳定 `beat_id` 片段，再由镜级 `正文回指.beat_refs[]` 进行引用。",
      "additionalProperties": false,
      "required": [
        "beat_id",
        "原文片段",
        "segment_type",
        "char_range"
      ],
      "properties": {
        "beat_id": {
          "type": "string",
          "description": "正文切分段的稳定标识。默认沿用 `3-Detail` 的 beat 语义，例如 `<group_id>-b01`。"
        },
        "原文片段": {
          "type": "string",
          "description": "当前切分段在 `剧本正文` 中的完整保留原文，不得摘要化。"
        },
        "anchor_summary": {
          "type": "string",
          "description": "对该正文片段的最小导演/调度摘要，便于 review 与 merge 理解；不得替代 `原文片段`。"
        },
        "segment_type": {
          "type": "string",
          "enum": [
            "动作",
            "对白",
            "反应",
            "环境",
            "转折",
            "复合"
          ],
          "description": "正文片段的主要功能类型。"
        },
        "char_range": {
          "$ref": "#/$defs/script_segment_char_range"
        },
        "speaker_hint": {
          "type": "string",
          "description": "当片段以对白或话轮为主时，可选记录主要说话者。"
        }
      }
    },
    "shot_script_reference": {
      "type": "object",
      "description": "镜级正文回指。镜头不再复制整段 `剧本正文`，而是通过 `beat_refs[]` 回链组级 `正文切分参考[]`；若镜头属于反应镜、插入镜或组合镜，则用 `coverage_mode` 显式说明它与原文的关系。",
      "additionalProperties": false,
      "required": [
        "beat_refs",
        "coverage_mode"
      ],
      "properties": {
        "beat_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          },
          "description": "当前镜头回指的正文切分段 `beat_id` 列表。"
        },
        "coverage_mode": {
          "type": "string",
          "enum": [
            "direct",
            "reaction",
            "insert",
            "bridge",
            "composite"
          ],
          "description": "镜头与原文片段的覆盖关系：直接承接、反应镜、插入镜、桥接镜或复合镜。"
        },
        "strategy_note": {
          "type": "string",
          "description": "当 `beat_refs[]` 与可见镜头事实不是简单 1:1 时，记录当前镜头如何处理该片段。"
        }
      }
    },
    "shot_detail": {
      "type": "object",
      "description": "镜级 canonical 槽位。自 `3-Detail` branch-owned 重构起，shared root 的主命名应直接对齐 child skill 包名：`角色表现 / 运动表现 / 氛围表现 / 视觉强化 / 分镜构图 / 摄影美学 / 运镜手法 / 转场特效`。旧字段名中仅 `人物表演锚点 / 动作路径 / 空间氛围 / 视觉抓手 / 构图骨架 / 分镜表现` 与 descriptor 兼容槽继续保留为兼容别名或过渡投影；`人物表演 / 动作调度 / 视觉焦点 / 构图策略 / 摄影策略 / 运镜策略 / 转场策略` 已从 schema 主兼容层下收，不再作为 shared root 合法键。所有镜级文本默认执行反抽象写法，应优先呈现可见动作、位置、物件、光气与构图证据。自本版起，镜级与组级正文的关系必须通过 `正文回指 -> 正文切分参考` 显式回链，而不是让读者自行从整组 prose 逆推分镜边界。",
      "additionalProperties": false,
      "required": [
        "分镜ID",
        "时间段",
        "正文回指",
        "角色背景面",
        "角色站位走位",
        "道具及状态"
      ],
      "properties": {
        "分镜ID": {
          "type": "string"
        },
        "时间段": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "开始秒",
            "结束秒"
          ],
          "properties": {
            "开始秒": {
              "type": "number",
              "minimum": 0,
              "description": "当前分镜组内的相对开始秒位；组内首镜通常从 0 开始，不使用全集累积时间。"
            },
            "结束秒": {
              "type": "number",
              "minimum": 0,
              "description": "当前分镜组内的相对结束秒位；最后一镜的结束秒通常应与所在组 `总时长` 对齐。"
            }
          },
          "description": "以秒为单位的组内相对闭区间；时间零点以当前分镜组起点为准，不得写成全集累积时间线。"
        },
        "正文回指": {
          "$ref": "#/$defs/shot_script_reference"
        },
        "角色背景面": {
          "type": "string",
          "description": "在角色中心主义下，交代当前镜头作为角色背景的具体场景方位面，例如东西南北面、入口/出口、内外侧或墙面/尽头关系。"
        },
        "角色站位走位": {
          "type": "string",
          "description": "明确角色在镜头中的当前位置、相对层次与位移路径，要求包含走位/移位信息，不只写静态站位。服装信息默认上收至 `组间设计.出场角色及穿搭`。"
        },
        "道具及状态": {
          "type": "string"
        },
        "角色表现": {
          "$ref": "#/$defs/watermoon_character_design"
        },
        "人物表演锚点": {
          "description": "deprecated alias；新流程优先写入 `角色表现`。",
          "$ref": "#/$defs/watermoon_character_design"
        },
        "运动表现": {
          "$ref": "#/$defs/watermoon_motion_design"
        },
        "动作路径": {
          "description": "deprecated alias；新流程优先写入 `运动表现`。",
          "$ref": "#/$defs/watermoon_motion_design"
        },
        "氛围表现": {
          "$ref": "#/$defs/watermoon_atmosphere_design"
        },
        "空间氛围": {
          "description": "deprecated alias；新流程优先写入 `氛围表现`。",
          "$ref": "#/$defs/watermoon_atmosphere_design"
        },
        "视觉强化": {
          "$ref": "#/$defs/watermoon_visual_design"
        },
        "视觉抓手": {
          "description": "deprecated alias；新流程优先写入 `视觉强化`。",
          "$ref": "#/$defs/watermoon_visual_design"
        },
        "分镜构图": {
          "description": "canonical 构图字段，直接对齐 `1-分镜构图` child skill。推荐写对象形态；bootstrap_compat 期允许 legacy string 过渡值。",
          "oneOf": [
            {
              "$ref": "#/$defs/jinghua_composition_design"
            },
            {
              "type": "string"
            }
          ]
        },
        "分镜表现": {
          "type": "string",
          "description": "deprecated legacy 兼容投影槽。若仍填写，只能是对 `分镜构图` 的具像摘要，不得再与 canonical 并行演化。"
        },
        "构图骨架": {
          "description": "deprecated alias；新流程优先写入 `分镜构图`。",
          "$ref": "#/$defs/jinghua_composition_design"
        },
        "摄影美学": {
          "description": "canonical 摄影字段，直接对齐 `2-摄影美学` child skill。推荐写对象形态；bootstrap_compat 期允许 legacy string 过渡值。",
          "oneOf": [
            {
              "$ref": "#/$defs/jinghua_cinematography_design"
            },
            {
              "type": "string"
            }
          ]
        },
        "运镜手法": {
          "description": "canonical 运镜字段，直接对齐 `3-运镜手法` child skill。推荐写对象形态；bootstrap_compat 期允许 legacy string 过渡值。",
          "oneOf": [
            {
              "$ref": "#/$defs/jinghua_camera_design"
            },
            {
              "type": "string"
            }
          ]
        },
        "转场特效": {
          "description": "canonical 转场字段。只有确实需要显式组内/组间转场或特效桥接时才填写；bootstrap_compat 期允许 legacy object 过渡值。",
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/jinghua_transition_design"
            }
          ]
        },
        "景别": {
          "type": "string",
          "description": "可选镜头描述子槽；例如 `中景`、`近景`、`特写`。仅在下游消费方明确需要 descriptor 补充时才填写；canonical example 默认省略。"
        },
        "镜头类型兼容": {
          "type": "string",
          "description": "deprecated compatibility slot；旧数据中用于承载定场镜头/关系建立镜头等信息。新流程优先使用 `镜头类型` 与 `分镜构图` 对象；canonical example 默认省略。"
        },
        "镜头框架": {
          "type": "string",
          "description": "可选镜头描述子槽；压缩主体/陪体/背景关系与构图结果。仅在下游消费方明确需要 descriptor 补充时才填写；canonical example 默认省略。"
        },
        "镜头类型": {
          "type": "string",
          "description": "可选镜头描述子槽；说明当前镜头在叙事链中的职责。仅在下游消费方明确需要 descriptor 补充时才填写；canonical example 默认省略。"
        },
        "镜头视角": {
          "type": "string",
          "description": "可选镜头描述子槽；例如 `平视`、`俯视`、`仰视`、`过肩视角`。仅在下游消费方明确需要 descriptor 补充时才填写；canonical example 默认省略。"
        },
        "镜头速度": {
          "type": "string",
          "description": "可选镜头运动速度槽；用于把运动路线与速度档分离，例如 `慢速压近`、`中速跟随`、`急停后极慢收束`。旧数据允许缺省，新数据若填写应与 `运镜手法` 保持一致；canonical example 默认省略。"
        }
      }
    },
    "watermoon_character_design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "动作戏",
        "内心戏"
      ],
      "properties": {
        "动作戏": {
          "type": "string",
          "description": "直接对齐 `1-角色表现/动作戏` 叶子，回答“这一拍身体或外显动作怎样成立”。不得写成景别、机位、运镜或镜头速度术语。"
        },
        "对话戏": {
          "type": "string",
          "description": "直接对齐 `1-角色表现/对话戏` 叶子。仅在当前拍存在明确对白、话轮攻守、抢话、吞话、截断或失口时填写。重点不是复述对白内容，而是回答“谁先发、谁截断、谁吞回、这一拍的话是用什么腔调、语态、断句、气口、停顿与潜台词带压”。若当前拍无明确对话，则默认省略。不得与 `动作戏 / 内心戏` 机械同句。"
        },
        "对手戏": {
          "type": "string",
          "description": "deprecated alias；旧数据中用于承载互动攻守。新流程优先使用可选 `对话戏`，且 canonical example 默认省略此槽。"
        },
        "内心戏": {
          "type": "string",
          "description": "直接对齐 `1-角色表现/内心戏` 叶子，回答“人物内里哪股情绪或意图被压在动作底下”。不得退化成抽象空话。"
        }
      }
    },
    "watermoon_motion_design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "逻辑性",
        "位置和方向",
        "一致性"
      ],
      "properties": {
        "逻辑性": {
          "type": "string",
