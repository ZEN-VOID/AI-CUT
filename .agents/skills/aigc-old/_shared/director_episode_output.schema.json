{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "aigc/_shared/director_episode_output.schema.json",
  "type": "object",
  "allOf": [
    {
      "if": {
        "properties": {
          "metadata": {
            "properties": {
              "document_phase": {
                "enum": [
                  "detail_in_progress",
                  "ready"
                ]
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "final_output": {
            "properties": {
              "main_content": {
                "properties": {
                  "分镜组列表": {
                    "items": {
                      "required": [
                        "正文切分参考"
                      ],
                      "properties": {
                        "正文切分参考": {
                          "minItems": 1
                        },
                        "分镜明细": {
                          "minItems": 1,
                          "items": {
                            "required": [
                              "正文回指"
                            ],
                            "properties": {
                              "正文回指": {
                                "required": [
                                  "beat_refs",
                                  "coverage_mode"
                                ],
                                "properties": {
                                  "beat_refs": {
                                    "minItems": 1
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "metadata": {
            "properties": {
              "document_phase": {
                "const": "directing_in_progress"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "final_output": {
            "properties": {
              "main_content": {
                "properties": {
                  "分镜组列表": {
                    "items": {
                      "properties": {
                        "组间设计": {
                          "properties": {
                            "全局风格": {
                              "maxLength": 220
                            },
                            "类型元素": {
                              "maxLength": 50
                            },
                            "导演意图": {
                              "maxLength": 100
                            }
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  ],
  "additionalProperties": false,
  "required": [
    "metadata",
    "final_output"
  ],
  "properties": {
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "skill_id",
        "template_version",
        "source_route",
        "episode_id",
        "document_phase",
        "created_at"
      ],
      "properties": {
        "schema_version": {
          "type": "string",
          "const": "aigc/director-episode-output/v1"
        },
        "skill_id": {
          "type": "string"
        },
        "template_version": {
          "type": "string"
        },
        "source_route": {
          "type": "string"
        },
        "source_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "source_type",
            "preset_retention_mode",
            "detail_expansion_mode",
            "locked_preset_axes",
            "preset_registry"
          ],
          "properties": {
            "source_type": {
              "type": "string",
              "enum": [
                "novel_original",
                "script_original",
                "storyboard_script",
                "oral_story_transcript",
                "hybrid_story_text"
              ]
            },
            "preset_retention_mode": {
              "type": "string",
              "enum": [
                "standard",
                "preserve_and_extend",
                "preserve_only"
              ]
            },
            "detail_expansion_mode": {
              "type": "string",
              "enum": [
                "free_expansion",
                "guided_expansion",
                "respect_storyboard_presets"
              ]
            },
            "locked_preset_axes": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "preset_registry": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/preset_anchor"
              }
            }
          }
        },
        "episode_id": {
          "type": "string"
        },
        "document_phase": {
          "type": "string",
          "enum": [
            "bootstrapped",
            "planning_seeded",
            "directing_in_progress",
            "detail_in_progress",
            "ready"
          ]
        },
        "created_at": {
          "type": "string"
        }
      }
    },
    "thinking_chain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "thinking_goal",
        "key_steps",
        "conclusion"
      ],
      "properties": {
        "thinking_goal": {
          "type": "string"
        },
        "key_steps": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "#/$defs/thinking_step"
          }
        },
        "conclusion": {
          "type": "string"
        }
      }
    },
    "final_output": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "deliverable_type",
        "main_content",
        "acceptance_notes"
      ],
      "properties": {
        "deliverable_type": {
          "type": "string",
          "const": "director_episode_output"
        },
        "main_content": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "分镜组列表"
          ],
          "properties": {
            "分镜组列表": {
              "type": "array",
              "minItems": 0,
              "items": {
                "$ref": "#/$defs/storyboard_group"
              }
            }
          }
        },
        "acceptance_notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  },
  "$defs": {
    "thinking_step": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "step_id",
        "focus",
        "evidence",
        "judgment"
      ],
      "properties": {
        "step_id": {
          "type": "string"
        },
        "focus": {
          "type": "string"
        },
        "evidence": {
          "type": "string"
        },
        "judgment": {
          "type": "string"
        }
      }
    },
    "preset_anchor": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "anchor_id",
        "source_span",
        "lock_level",
        "owned_axes",
        "expandable_axes",
        "forbidden_changes",
        "projected_group_ids",
        "projected_shot_mode"
      ],
      "properties": {
        "anchor_id": {
          "type": "string"
        },
        "source_span": {
          "type": "string"
        },
        "lock_level": {
          "type": "string",
          "enum": [
            "hard_lock",
            "soft_lock",
            "reference_only"
          ]
        },
        "owned_axes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "expandable_axes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "forbidden_changes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "projected_group_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "projected_shot_mode": {
          "type": "string",
          "enum": [
            "single_anchor_single_shot",
            "single_anchor_multi_shot",
            "multi_anchor_fixed",
            "reference_only"
          ]
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "storyboard_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "分镜组ID",
        "总时长",
        "剧本正文",
        "组间设计",
        "分镜切换",
        "分镜明细"
      ],
      "properties": {
        "分镜组ID": {
          "type": "string"
        },
        "总时长": {
          "type": "number",
          "minimum": 0
        },
        "剧本正文": {
          "type": "string"
        },
        "正文切分参考": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/script_segment_reference"
          }
        },
        "组间设计": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "全局风格",
            "类型元素",
            "导演意图",
            "出场角色及穿搭"
          ],
          "properties": {
            "全局风格": {
              "type": "string"
            },
            "类型元素": {
              "type": "string"
            },
            "导演意图": {
              "type": "string"
            },
            "出场角色及穿搭": {
              "type": "string"
            }
          }
        },
        "分镜切换": {
          "type": "integer",
          "minimum": 1
        },
        "分镜明细": {
          "type": "array",
          "minItems": 0,
          "items": {
            "$ref": "#/$defs/shot_detail"
          }
        }
      }
    },
    "script_segment_char_range": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "start",
        "end"
      ],
      "properties": {
        "start": {
          "type": "integer",
          "minimum": 0
        },
        "end": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "script_segment_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "beat_id",
        "原文片段",
        "segment_type",
        "char_range"
      ],
      "properties": {
        "beat_id": {
          "type": "string"
        },
        "原文片段": {
          "type": "string"
        },
        "anchor_summary": {
          "type": "string"
        },
        "segment_type": {
          "type": "string",
          "enum": [
            "动作",
            "对白",
            "反应",
            "环境",
            "转折",
            "复合"
          ]
        },
        "char_range": {
          "$ref": "#/$defs/script_segment_char_range"
        },
        "speaker_hint": {
          "type": "string"
        }
      }
    },
    "shot_script_reference": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "beat_refs",
        "coverage_mode"
      ],
      "properties": {
        "beat_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "coverage_mode": {
          "type": "string",
          "enum": [
            "direct",
            "reaction",
            "insert",
            "bridge",
            "composite"
          ]
        },
        "strategy_note": {
          "type": "string"
        }
      }
    },
    "shot_detail": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "分镜ID",
        "时间段",
        "正文回指",
        "角色背景面",
        "角色站位走位",
        "道具及状态"
      ],
      "properties": {
        "分镜ID": {
          "type": "string"
        },
        "时间段": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "开始秒",
            "结束秒"
          ],
          "properties": {
            "开始秒": {
              "type": "number",
              "minimum": 0
            },
            "结束秒": {
              "type": "number",
              "minimum": 0
            }
          }
        },
        "正文回指": {
          "$ref": "#/$defs/shot_script_reference"
        },
        "角色背景面": {
          "type": "string"
        },
        "角色站位走位": {
          "type": "string"
        },
        "道具及状态": {
          "type": "string"
        },
        "角色表现": {
          "$ref": "#/$defs/watermoon_character_design"
        },
        "人物表演锚点": {
          "$ref": "#/$defs/watermoon_character_design"
        },
        "运动表现": {
          "$ref": "#/$defs/watermoon_motion_design"
        },
        "动作路径": {
          "$ref": "#/$defs/watermoon_motion_design"
        },
        "氛围表现": {
          "$ref": "#/$defs/watermoon_atmosphere_design"
        },
        "空间氛围": {
          "$ref": "#/$defs/watermoon_atmosphere_design"
        },
        "视觉强化": {
          "$ref": "#/$defs/watermoon_visual_design"
        },
        "视觉抓手": {
          "$ref": "#/$defs/watermoon_visual_design"
        },
        "分镜构图": {
          "oneOf": [
            {
              "$ref": "#/$defs/jinghua_composition_design"
            },
            {
              "type": "string"
            }
          ]
        },
        "分镜表现": {
          "type": "string"
        },
        "构图骨架": {
          "$ref": "#/$defs/jinghua_composition_design"
        },
        "摄影美学": {
          "oneOf": [
            {
              "$ref": "#/$defs/jinghua_cinematography_design"
            },
            {
              "type": "string"
            }
          ]
        },
        "运镜手法": {
          "oneOf": [
            {
              "$ref": "#/$defs/jinghua_camera_design"
            },
            {
              "type": "string"
            }
          ]
        },
        "转场特效": {
          "oneOf": [
            {
              "type": "string"
            },
            {
              "$ref": "#/$defs/jinghua_transition_design"
            }
          ]
        },
        "景别": {
          "type": "string"
        },
        "镜头类型兼容": {
          "type": "string"
        },
        "镜头框架": {
          "type": "string"
        },
        "镜头类型": {
          "type": "string"
        },
        "镜头视角": {
          "type": "string"
        },
        "镜头速度": {
          "type": "string"
        }
      }
    },
    "watermoon_character_design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "动作戏",
        "内心戏"
      ],
      "properties": {
        "动作戏": {
          "type": "string"
        },
        "对话戏": {
          "type": "string"
        },
        "对手戏": {
          "type": "string"
        },
        "内心戏": {
          "type": "string"
        }
      }
    },
    "watermoon_motion_design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "逻辑性",
        "位置和方向",
        "一致性"
      ],
      "properties": {
        "逻辑性": {
          "type": "string"
        },
        "位置和方向": {
          "type": "string"
        },
        "一致性": {
          "type": "string"
        }
      }
    },
    "watermoon_atmosphere_design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "层次",
        "空间诗学",
        "意境"
      ],
      "properties": {
        "层次": {
          "type": "string"
        },
        "空间诗学": {
          "type": "string"
        },
        "意境": {
          "type": "string"
        }
      }
    },
    "watermoon_visual_design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "冲击力",
        "观赏性",
        "品味"
      ],
      "properties": {
        "冲击力": {
          "type": "string"
        },
        "观赏性": {
          "type": "string"
        },
        "品味": {
          "type": "string"
        }
      }
    },
    "jinghua_composition_design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "景别景深",
        "镜头类型",
        "构图形式"
      ],
      "properties": {
        "景别景深": {
          "type": "string"
        },
        "镜头类型": {
          "type": "string"
        },
        "构图形式": {
          "type": "string"
        }
      }
    },
    "jinghua_cinematography_design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "光影",
        "色彩",
        "质感"
      ],
      "properties": {
        "光影": {
          "type": "string"
        },
        "色彩": {
          "type": "string"
        },
        "质感": {
          "type": "string"
        }
      }
    },
    "jinghua_camera_design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "变化",
        "速度",
        "组合"
      ],
      "properties": {
        "变化": {
          "type": "string"
        },
        "速度": {
          "type": "string"
        },
        "组合": {
          "type": "string"
        }
      }
    },
    "jinghua_transition_design": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "切接逻辑",
        "组内衔接",
        "组间或特效策略"
      ],
      "properties": {
        "切接逻辑": {
          "type": "string"
        },
        "组内衔接": {
          "type": "string"
        },
        "组间或特效策略": {
          "type": "string"
        }
      }
    },
    "detail_branch_process_sidecar": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metadata",
        "group_branch_patches"
      ],
      "properties": {
        "metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "skill_id",
            "episode_id",
            "parent_owner",
            "branch_owner",
            "source_root",
            "generated_at",
            "review_status"
          ],
          "properties": {
            "schema_version": {
              "type": "string",
              "const": "aigc/detail-branch-process-sidecar/v1"
            },
            "skill_id": {
              "type": "string"
            },
            "episode_id": {
              "type": "string"
            },
            "parent_owner": {
              "type": "string",
              "enum": [
                "水月",
                "镜花"
              ]
            },
            "branch_owner": {
              "type": "string"
            },
            "source_root": {
              "type": "string"
            },
            "generated_at": {
              "type": "string"
            },
            "review_status": {
              "type": "string",
              "enum": [
                "pending",
                "reviewed",
                "blocked"
              ]
            }
          }
        },
        "group_branch_patches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/detail_branch_group_patch"
          }
        }
      }
    },
    "detail_branch_group_patch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group_id",
        "target_json_paths",
        "thinking_process",
        "patch_payload",
        "review_trace"
      ],
      "properties": {
        "group_id": {
          "type": "string"
        },
        "target_json_paths": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "thinking_process": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "context_anchor",
            "creative_thesis",
            "execution_steps",
            "self_check"
          ],
          "properties": {
            "context_anchor": {
              "type": "string"
            },
            "creative_thesis": {
              "type": "string"
            },
            "execution_steps": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "self_check": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "patch_payload": {
          "type": "object"
        },
        "review_trace": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "requested_reviewers",
            "key_findings",
            "apply_decision"
          ],
          "properties": {
            "requested_reviewers": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "key_findings": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "apply_decision": {
              "type": "string"
            }
          }
        }
      }
    },
    "detail_patch_sidecar": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metadata",
        "group_patches"
      ],
      "properties": {
        "metadata": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "schema_version",
            "skill_id",
            "episode_id",
            "patch_owner",
            "source_root",
            "script_body_policy",
            "generated_at"
          ],
          "properties": {
            "schema_version": {
              "type": "string",
              "enum": [
                "aigc/detail-patch-sidecar/v1",
                "aigc/detail-branch-bundle-sidecar/v1"
              ]
            },
            "skill_id": {
              "type": "string"
            },
            "episode_id": {
              "type": "string"
            },
            "patch_owner": {
              "type": "string",
              "enum": [
                "水月",
                "镜花"
              ]
            },
            "source_root": {
              "type": "string"
            },
            "script_body_policy": {
              "type": "string",
              "const": "inherit_only"
            },
            "generated_at": {
              "type": "string"
            },
            "bundle_mode": {
              "type": "string",
              "enum": [
                "legacy_merge",
                "assembly_only"
              ]
            }
          }
        },
        "branch_sidecars": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "group_patches": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/detail_group_patch"
          }
        }
      }
    },
    "detail_group_patch": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group_id",
        "target_fields"
      ],
      "properties": {
        "group_id": {
          "type": "string"
        },
        "target_fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "group_design_patch": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
