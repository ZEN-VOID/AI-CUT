{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "comic_page_animation_prompts.v1",
  "type": "object",
  "required": [
    "schema_version",
    "type_stack_ref",
    "type_pack_context",
    "prompt_prefix",
    "page_group",
    "video_generation_contract",
    "pages"
  ],
  "properties": {
    "schema_version": {
      "const": "comic_page_animation_prompts.v1"
    },
    "source_nine_blade_json": {
      "type": "string"
    },
    "type_stack_ref": {
      "type": "object",
      "required": ["method_kernel", "base", "primary", "active_packs"],
      "properties": {
        "method_kernel": {"const": "comic-core-v1"},
        "base": {"type": "string"},
        "primary": {"type": "string"},
        "secondary": {"type": "array", "items": {"type": "string"}},
        "platform": {"type": "array", "items": {"type": "string"}},
        "audience": {"type": "array", "items": {"type": "string"}},
        "active_packs": {"type": "array", "minItems": 2, "items": {"type": "string"}}
      }
    },
    "type_pack_context": {
      "type": "object",
      "required": ["resolution_mode", "knowledge_refs", "semantic_tags", "stage_projection", "control_surface"],
      "properties": {
        "resolution_mode": {"type": "string"},
        "knowledge_refs": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "knowledge_digest": {"type": "array", "items": {"type": "string"}},
        "control_surface_digest": {"type": "array", "items": {"type": "string"}},
        "semantic_tags": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "projection_summary": {"type": "object"},
        "control_surface": {
          "type": "object",
          "required": ["conflict_engine", "role_matrix", "page_turn_mechanism", "panel_grammar", "visual_carrier", "dialogue_register", "motif_system", "failure_modes"],
          "properties": {
            "conflict_engine": {"type": "object"},
            "role_matrix": {"type": "object"},
            "page_turn_mechanism": {"type": "object"},
            "panel_grammar": {"type": "object"},
            "visual_carrier": {"type": "object"},
            "dialogue_register": {"type": "object"},
            "motif_system": {"type": "object"},
            "failure_modes": {"type": "array", "items": {"type": ["string", "object"]}}
          }
        },
        "stage_projection": {
          "type": "object",
          "required": ["script_adaptation", "nine_blade_prompting", "image_generation", "animation_generation", "episode_poster"],
          "properties": {
            "script_adaptation": {"type": "object"},
            "nine_blade_prompting": {"type": "object"},
            "image_generation": {"type": "object"},
            "animation_generation": {"type": "object"},
            "episode_poster": {"type": "object"}
          }
        }
      }
    },
    "source_images_dir": {
      "type": "string"
    },
    "prompt_prefix": {
      "type": "string",
      "minLength": 20
    },
    "page_group": {
      "type": "object",
      "required": [
        "group_id"
      ],
      "properties": {
        "group_id": {
          "type": "string"
        },
        "group_index": {
          "type": "integer"
        },
        "total_groups": {
          "type": "integer"
        }
      }
    },
    "continuity_context": {
      "type": "object"
    },
    "video_generation_contract": {
      "type": "object",
      "required": [
        "provider",
        "mode",
        "model",
        "seconds",
        "size",
        "input_reference_mode",
        "aspect_ratio"
      ],
      "properties": {
        "provider": {
          "const": "man-tui"
        },
        "mode": {
          "const": "image_to_video"
        },
        "model": {
          "const": "sora-2"
        },
        "seconds": {
          "type": "integer",
          "enum": [10, 15]
        },
        "size": {
          "type": "string",
          "enum": ["720x1280", "1280x720"]
        },
        "input_reference_mode": {
          "type": "string",
          "const": "public_url_required"
        },
        "aspect_ratio": {
          "const": "9:16"
        }
      }
    },
    "pages": {
      "type": "array",
      "minItems": 9,
      "maxItems": 9,
      "items": {
        "type": "object",
        "required": [
          "page_number",
          "page_role",
          "source_image",
          "storyboard_policy",
          "layout",
          "shot_plan",
          "video_prompt"
        ],
        "properties": {
          "page_number": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9
          },
          "page_role": {
            "type": "string"
          },
          "source_image": {
            "type": "string"
          },
          "input_reference_url": {
            "type": ["string", "null"]
          },
          "active_character_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "scene_id": {
            "type": "string"
          },
          "page_number_overlay": {
            "type": "object"
          },
          "storyboard_policy": {
            "type": "object",
            "required": [
              "panel_to_shot",
              "reading_order"
            ],
            "properties": {
              "panel_to_shot": {
                "type": "string"
              },
              "reading_order": {
                "type": "string"
              }
            }
          },
          "layout": {
            "type": "object"
          },
          "shot_plan": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": [
                "shot_index",
                "source_panel_id",
                "shot",
                "action",
                "camera_motion",
                "subject_motion"
              ],
              "properties": {
                "shot_index": {
                  "type": "integer",
                  "minimum": 1
                },
                "source_panel_id": {
                  "type": "string"
                },
                "shot": {
                  "type": "string"
                },
                "action": {
                  "type": "string"
                },
                "camera_motion": {
                  "type": "string"
                },
                "subject_motion": {
                  "type": "string"
                },
                "text_handling": {
                  "type": "string"
                }
              }
            }
          },
          "video_prompt": {
            "type": "string",
            "minLength": 100
          }
        }
      }
    }
  }
}
