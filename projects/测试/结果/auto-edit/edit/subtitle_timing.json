  "cues": [
    {
      "index": 1,
      "start": 0.1,
      "end": 1.045,
      "text": "我靠，"
    },
    {
      "index": 2,
      "start": 1.045,
      "end": 3.173,
      "text": "ai漫剧赛道直接他妈大结局了。"
    },
    {
      "index": 3,
      "start": 3.173,
      "end": 6.297,
      "text": "Gemini three加 gptT images two 的出现，"
    },
    {
      "index": 4,
      "start": 6.297,
      "end": 7.806,
      "text": "直接宣布了比赛结束。"
    },
    {
      "index": 5,
      "start": 7.806,
      "end": 9.316,
      "text": "操作简单到我想骂街，"
    },
    {
      "index": 6,
      "start": 9.316,
      "end": 11.278,
      "text": "就把你那破小说往里头一丢，"
    },
    {
      "index": 7,
      "start": 11.278,
      "end": 13.693,
      "text": "大模型就能自动接管一切推理剧情，"
    },
    {
      "index": 8,
      "start": 13.693,
      "end": 15.202,
      "text": "脚本直接给你生成好，"
    },
    {
      "index": 9,
      "start": 15.202,
      "end": 17.617,
      "text": "不用你费半天劲研究啥复杂提示词，"
    },
    {
      "index": 10,
      "start": 17.617,
      "end": 20.183,
      "text": "不用你绞尽脑汁写什么智能分镜指令，"
    },
    {
      "index": 11,
      "start": 20.183,
      "end": 23.05,
      "text": "直接给你出连贯到离谱的电影级分镜剧本。"
    },
    {
      "index": 12,
      "start": 23.05,
      "end": 24.107,
      "text": "最牛逼的来了，"
    },
    {
      "index": 13,
      "start": 24.107,
      "end": 26.974,
      "text": "他直接把人物不一致的千古难题给干碎了。"
    },
    {
      "index": 14,
      "start": 26.974,
      "end": 29.389,
      "text": "一键出人物三视图场景，全套道具。"
    },
    {
      "index": 15,
      "start": 29.389,
      "end": 32.559,
      "text": "你家主角从片头到片尾长得半毛钱，不带差的，"
    },
    {
      "index": 16,
      "start": 32.559,
      "end": 34.068,
      "text": "想换画风，一键搞定。"
    },
    {
      "index": 17,
      "start": 34.068,
      "end": 35.013,
      "text": "古风赛露露。"
    },
    {
      "index": 18,
      "start": 35.013,
      "end": 36.235,
      "text": "国风3D日系动漫，"
    },
    {
      "index": 19,
      "start": 36.235,
      "end": 37.18,
      "text": "啥风格都有，"
    },
    {
      "index": 20,
      "start": 37.18,
      "end": 38.84,
      "text": "做完直接一键导出成片，"
    },
    {
      "index": 21,
      "start": 38.84,
      "end": 39.897,
      "text": "全程云端运行，"
    },
    {
      "index": 22,
      "start": 39.897,
      "end": 42.161,
      "text": "半毛钱不吃你电脑配置，就问你，"
    },
    {
      "index": 23,
      "start": 42.161,
      "end": 43.368,
      "text": "这成品够不够顶？"
    },
    {
      "index": 24,
      "start": 43.368,
      "end": 45.21,
      "text": "别 time 追着我要工具了，"
    },
    {
      "index": 25,
      "start": 45.21,
      "end": 46.719,
      "text": "我全给你们整理好了，"
    },
    {
      "index": 26,
      "start": 46.719,
      "end": 47.775,
      "text": "只要是我粉丝，"
    },
    {
      "index": 27,
      "start": 47.775,
      "end": 49.066,
      "text": "留下三个8，直接。"
    }
  ]
